<% content_for :title, "Problems" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 24px 0;">Problems</h1>

  <% if @blocking.empty? && @no_po_cost.empty? && @backordered.empty? && @stuck_orders.empty? %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :check_circle)
      bs.with_heading(tag: :h2) { "No problems!" }
      bs.with_description { "Go take a nap or something." }
    end %>
  <% end %>

  <% if @blocking.any? %>
    <div style="margin-bottom: 32px;">
      <h2 style="font-size: 16px; font-weight: 600; margin: 0 0 8px 0; color: var(--fgColor-danger);">Dispatch Blockers</h2>
      <p style="color: var(--fgColor-muted); font-size: 14px; margin: 0 0 12px 0;">These enabled SKUs have no cost data at all — no PO cost, no override. Orders containing them will refuse to dispatch.</p>
      <%= render Primer::Beta::BorderBox.new do |box|
        box.with_header do %>
          <div style="display: flex; justify-content: space-between; width: 100%;">
            <span style="font-weight: 600; min-width: 120px;">SKU</span>
            <span style="font-weight: 600; flex: 1;">Name</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">In Stock</span>
            <span style="font-weight: 600; min-width: 100px; text-align: right;">Zenventory</span>
          </div>
        <% end
        @blocking.each do |sku|
          box.with_row do %>
            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
              <code style="min-width: 120px;"><%= link_to sku.sku, warehouse_sku_path(sku), style: "color: var(--fgColor-accent);" %></code>
              <span style="flex: 1;"><%= sku.name %></span>
              <span style="min-width: 80px; text-align: right;"><%= sku.in_stock || "—" %></span>
              <span style="min-width: 100px; text-align: right;">
                <% if sku.zenventory_url %>
                  <%= link_to "view", sku.zenventory_url, target: "_blank", style: "color: var(--fgColor-accent); font-size: 13px;" %>
                <% end %>
              </span>
            </div>
          <% end
        end
      end %>
    </div>
  <% end %>

  <% if @no_po_cost.any? %>
    <div style="margin-bottom: 32px;">
      <h2 style="font-size: 16px; font-weight: 600; margin: 0 0 8px 0; color: var(--fgColor-attention);">Missing PO Cost Data</h2>
      <p style="color: var(--fgColor-muted); font-size: 14px; margin: 0 0 12px 0;">These enabled SKUs have no <code>average_po_cost</code> from Zenventory but are covered by a fallback. The PO data should be fixed.</p>
      <%= render Primer::Beta::BorderBox.new do |box|
        box.with_header do %>
          <div style="display: flex; justify-content: space-between; width: 100%;">
            <span style="font-weight: 600; min-width: 120px;">SKU</span>
            <span style="font-weight: 600; flex: 1;">Name</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">Cost</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">Source</span>
            <span style="font-weight: 600; min-width: 100px; text-align: right;">Zenventory</span>
          </div>
        <% end
        @no_po_cost.each do |sku|
          box.with_row do %>
            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
              <code style="min-width: 120px;"><%= link_to sku.sku, warehouse_sku_path(sku), style: "color: var(--fgColor-accent);" %></code>
              <span style="flex: 1;"><%= sku.name %></span>
              <span style="min-width: 80px; text-align: right;"><%= number_to_currency(sku.declared_unit_cost) %></span>
              <span style="min-width: 80px; text-align: right; color: var(--fgColor-muted);">
                <%= sku.declared_unit_cost_override&.positive? ? "override" : "???" %>
              </span>
              <span style="min-width: 100px; text-align: right;">
                <% if sku.zenventory_url %>
                  <%= link_to "view", sku.zenventory_url, target: "_blank", style: "color: var(--fgColor-accent); font-size: 13px;" %>
                <% end %>
              </span>
            </div>
          <% end
        end
      end %>
    </div>
  <% end %>

  <% if @backordered.any? %>
    <div style="margin-bottom: 32px;">
      <h2 style="font-size: 16px; font-weight: 600; margin: 0 0 8px 0; color: var(--fgColor-attention);">Backordered Without Enough Inbound</h2>
      <p style="color: var(--fgColor-muted); font-size: 14px; margin: 0 0 12px 0;">These SKUs are oversold and don't have enough inbound stock to cover the deficit.</p>
      <%= render Primer::Beta::BorderBox.new do |box|
        box.with_header do %>
          <div style="display: flex; justify-content: space-between; width: 100%;">
            <span style="font-weight: 600; min-width: 120px;">SKU</span>
            <span style="font-weight: 600; flex: 1;">Name</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">In Stock</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">Inbound</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">Shortfall</span>
          </div>
        <% end
        @backordered.each do |sku|
          box.with_row do %>
            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
              <code style="min-width: 120px;"><%= link_to sku.sku, warehouse_sku_path(sku), style: "color: var(--fgColor-accent);" %></code>
              <span style="flex: 1;"><%= sku.name %></span>
              <span style="min-width: 80px; text-align: right; color: var(--fgColor-danger); font-weight: 600;"><%= sku.in_stock %></span>
              <span style="min-width: 80px; text-align: right;"><%= sku.inbound || 0 %></span>
              <span style="min-width: 80px; text-align: right; color: var(--fgColor-danger); font-weight: 600;"><%= sku.in_stock.abs - (sku.inbound || 0) %></span>
            </div>
          <% end
        end
      end %>
    </div>
  <% end %>

  <% if @stuck_orders.any? %>
    <div style="margin-bottom: 32px;">
      <h2 style="font-size: 16px; font-weight: 600; margin: 0 0 8px 0; color: var(--fgColor-danger);">Stuck Orders</h2>
      <p style="color: var(--fgColor-muted); font-size: 14px; margin: 0 0 12px 0;">Dispatched over 2 weeks ago but never marked as mailed. Possible Zenventory sync issue or stuck at warehouse.</p>
      <%= render Primer::Beta::BorderBox.new do |box|
        box.with_header do %>
          <div style="display: flex; justify-content: space-between; width: 100%;">
            <span style="font-weight: 600; min-width: 120px;">Order</span>
            <span style="font-weight: 600; flex: 1;">Recipient</span>
            <span style="font-weight: 600; min-width: 100px;">Dispatched</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">Age</span>
            <span style="font-weight: 600; min-width: 100px; text-align: right;">Zenventory</span>
          </div>
        <% end
        @stuck_orders.each do |order|
          box.with_row do %>
            <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
              <code style="min-width: 120px;"><%= link_to order.hc_id, warehouse_order_path(order), style: "color: var(--fgColor-accent);" %></code>
              <span style="flex: 1;"><%= order.recipient_email %></span>
              <span style="min-width: 100px;"><%= order.dispatched_at.strftime("%b %d, %Y") %></span>
              <span style="min-width: 80px; text-align: right; color: var(--fgColor-danger);"><%= distance_of_time_in_words_to_now(order.dispatched_at) %></span>
              <span style="min-width: 100px; text-align: right;">
                <% if order.zenventory_url %>
                  <%= link_to "view", order.zenventory_url, target: "_blank", style: "color: var(--fgColor-accent); font-size: 13px;" %>
                <% end %>
              </span>
            </div>
          <% end
        end
      end %>
    </div>
  <% end %>
</div>
