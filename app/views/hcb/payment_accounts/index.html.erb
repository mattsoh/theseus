<% content_for :title, "HCB Payment Accounts" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h1 style="font-size: 24px; font-weight: 600; margin: 0;">HCB Payment Accounts</h1>
    <% if current_user.hcb_connected? %>
      <%= render Primer::Beta::Button.new(tag: :a, href: new_hcb_payment_account_path, scheme: :primary) do |btn|
        btn.with_leading_visual_icon(icon: :plus)
        "Add Organization"
      end %>
    <% end %>
  </div>

  <% if current_user.hcb_connected? %>
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
      <div>
        <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Your Organizations</h2>
        <% if @payment_accounts.any? %>
          <%= render Primer::Beta::BorderBox.new do |box|
            @payment_accounts.each do |account|
              box.with_row do %>
                <a href="<%= hcb_payment_account_path(account) %>" style="display: flex; justify-content: space-between; align-items: center; width: 100%; text-decoration: none; color: inherit;">
                  <div>
                    <div style="font-weight: 600;"><%= account.organization_name %></div>
                    <div style="font-size: 13px; color: var(--fgColor-muted);">Added <%= time_ago_in_words(account.created_at) %> ago</div>
                  </div>
                  <%= render Primer::Beta::Octicon.new(icon: :chevron_right, color: :muted) %>
                </a>
              <% end
            end
          end %>
        <% else %>
          <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
            bs.with_visual_icon(icon: :organization)
            bs.with_heading(tag: :h3) { "No organizations linked yet" }
            bs.with_description { "Add one to start paying for postage." }
            bs.with_primary_action(href: new_hcb_payment_account_path) { "Add Organization" }
          end %>
        <% end %>
      </div>

      <div>
        <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Account Status</h2>
        <%= render Primer::Beta::BorderBox.new do |box|
          box.with_body do %>
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
              <%= render Primer::Beta::Octicon.new(icon: :check_circle, color: :success) %>
              <span style="font-weight: 600; color: var(--fgColor-success);">HCB Connected</span>
            </div>
            <p style="font-size: 14px; color: var(--fgColor-muted); margin: 0;">
              Your account is linked to HCB. You can pay for postage using any of your organizations' funds.
            </p>
          <% end
        end %>
      </div>
    </div>
  <% else %>
    <div style="max-width: 500px; margin: 48px auto; text-align: center;">
      <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
        bs.with_visual_icon(icon: :link)
        bs.with_heading(tag: :h2) { "Connect to HCB" }
        bs.with_description { "Link your HCB account to pay for postage directly from your organization's funds." }
        bs.with_primary_action(href: new_hcb_oauth_connection_path) { "Connect HCB Account" }
      end %>
    </div>
  <% end %>
</div>
