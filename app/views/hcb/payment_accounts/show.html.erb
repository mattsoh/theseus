<% content_for :title, "#{@payment_account.organization_name} - HCB" %>

<div class="page-container--narrow">
  <h1 class="page-title" style="margin-bottom: 24px;"><%= @payment_account.organization_name %></h1>

  <h2 class="section-heading">Organization Details</h2>
  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box|
    box.with_row do %>
      <div class="kv-row"><span class="kv-label">Organization ID</span><code><%= @payment_account.organization_id %></code></div>
    <% end
    box.with_row do %>
      <div class="kv-row"><span class="kv-label">Added</span><span><%= @payment_account.created_at.strftime("%B %d, %Y") %></span></div>
    <% end
  end %>

  <div style="margin-top: 32px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: hcb_payment_accounts_path, scheme: :invisible, size: :small) do |btn|
      btn.with_leading_visual_icon(icon: :"arrow-left")
      "Back to HCB accounts"
    end %>
  </div>
</div>
