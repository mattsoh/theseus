<% content_for :title, "#{@payment_account.organization_name} - HCB" %>

<div style="max-width: 800px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 24px 0;"><%= @payment_account.organization_name %></h1>

  <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Organization Details</h2>
  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box|
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Organization ID</span><code><%= @payment_account.organization_id %></code></div>
    <% end
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Added</span><span><%= @payment_account.created_at.strftime("%B %d, %Y") %></span></div>
    <% end
  end %>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to HCB accounts", hcb_payment_accounts_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
