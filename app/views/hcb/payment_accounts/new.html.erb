<% content_for :title, "Add HCB Organization" %>

<div class="page-container--xs">
  <h1 class="page-title content-section">Add Organization</h1>

  <% if @organizations.any? %>
    <div class="content-section">
      <h2 class="section-heading">Select Organization</h2>
      <p class="page-subtitle mb-3">Choose which HCB organization to use for paying postage.</p>

      <%= form_with url: hcb_payment_accounts_path, method: :post do |f| %>
        <%= render Primer::Beta::BorderBox.new(mb: 4) do |box|
          @organizations.each do |org|
            box.with_row do %>
              <label class="radio-label-row">
                <%= f.radio_button :organization_id, org.id, class: "accent-radio" %>
                <span class="fw-medium"><%= org.name %></span>
              </label>
            <% end
          end
        end %>

        <div class="page-actions">
          <%= render Primer::Beta::Button.new(tag: :a, href: hcb_payment_accounts_path, scheme: :secondary) do
            "Cancel"
          end %>
          <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary) do |btn|
            btn.with_leading_visual_icon(icon: :check)
            "Add Organization"
          end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :organization)
      bs.with_heading(tag: :h3) { "No organizations available" }
      bs.with_description { "You don't belong to any HCB organizations, or all your organizations are already linked." }
      bs.with_primary_action(href: hcb_payment_accounts_path) { "Back" }
    end %>
  <% end %>

  <div class="back-link">
    <%= render Primer::Beta::Button.new(tag: :a, href: hcb_payment_accounts_path, scheme: :invisible, size: :small) do |btn|
      btn.with_leading_visual_icon(icon: :"arrow-left")
      "Back to HCB accounts"
    end %>
  </div>
</div>
