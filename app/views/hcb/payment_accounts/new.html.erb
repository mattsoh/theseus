<% content_for :title, "Add HCB Organization" %>

<div style="max-width: 600px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 24px 0;">Add Organization</h1>

  <% if @organizations.any? %>
    <div style="margin-bottom: 24px;">
      <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Select Organization</h2>
      <p style="color: var(--fgColor-muted); font-size: 14px; margin: 0 0 16px 0;">Choose which HCB organization to use for paying postage.</p>

      <%= form_with url: hcb_payment_accounts_path, method: :post do |f| %>
        <%= render Primer::Beta::BorderBox.new(mb: 4) do |box|
          @organizations.each do |org|
            box.with_row do %>
              <label style="display: flex; align-items: center; gap: 12px; cursor: pointer; width: 100%;">
                <%= f.radio_button :organization_id, org.id, style: "accent-color: var(--fgColor-accent);" %>
                <span style="font-weight: 500;"><%= org.name %></span>
              </label>
            <% end
          end
        end %>

        <div style="display: flex; gap: 8px;">
          <%= render Primer::Beta::Button.new(tag: :a, href: hcb_payment_accounts_path, scheme: :secondary) do
            "Cancel"
          end %>
          <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary) do |btn|
            btn.with_leading_visual_icon(icon: :check)
            "Add Organization"
          end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :organization)
      bs.with_heading(tag: :h3) { "No organizations available" }
      bs.with_description { "You don't belong to any HCB organizations, or all your organizations are already linked." }
      bs.with_primary_action(href: hcb_payment_accounts_path) { "Back" }
    end %>
  <% end %>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to HCB accounts", hcb_payment_accounts_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
