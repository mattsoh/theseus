<div style="max-width: 800px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 24px;">Regenerate Labels</h1>
  <%= form_with(model: @batch, url: regenerate_labels_letter_batch_path(@batch), method: :post) do |f| %>
    <div style="margin-bottom: 16px;">
      <%= f.label :template_cycle, "Templates to use:", style: "display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px;" %>
      <%= f.hidden_field :template_cycle, id: "selected_template", value: params[:template] %>
      <%= render "shared/template_picker", multiple: true %>
    </div>
    <div style="margin-bottom: 16px;">
      <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
        <%= f.check_box :include_qr_code, checked: true %>
        <span style="font-size: 14px; font-weight: 600;">Include QR Code</span>
      </label>
    </div>
    <div style="display: flex; gap: 8px; align-items: center;">
      <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary) do |btn|
        btn.with_leading_visual_icon(icon: :sync)
        "Regenerate Labels"
      end %>
      <%= render Primer::Beta::Button.new(tag: :a, href: letter_batch_path(@batch), scheme: :secondary) do
        "Cancel"
      end %>
    </div>
  <% end %>
</div>
