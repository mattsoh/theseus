<% content_for :title, "Template Previews" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 24px 0;">Letter Template Previews</h1>

  <%= render Primer::Beta::BorderBox.new do |box|
    @templates.each do |template|
      box.with_row do %>
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
          <div>
            <div style="font-weight: 600;"><%= template.to_s.split("::").last.humanize %></div>
            <code style="font-size: 12px; color: var(--fgColor-muted);"><%= template %></code>
          </div>
          <div style="display: flex; gap: 8px;">
            <%= render Primer::Beta::Button.new(tag: :a, href: template_preview_path(template), scheme: :secondary, size: :small, target: "_blank") do |btn|
              btn.with_leading_visual_icon(icon: :file)
              "Preview PDF"
            end %>
            <%= render Primer::Beta::Button.new(tag: :a, href: template_preview_path(template, qr: true), scheme: :secondary, size: :small, target: "_blank") do |btn|
              btn.with_leading_visual_icon(icon: :file)
              "With QR"
            end %>
          </div>
        </div>
      <% end
    end
  end %>
</div>
