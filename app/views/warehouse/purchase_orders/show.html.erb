<% content_for :title, "Purchase Order #{@purchase_order.order_number.presence || "##{@purchase_order.id}"}" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="margin-bottom: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 16px;">
      <div>
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
          <h1 style="font-size: 24px; font-weight: 600; margin: 0; font-family: var(--fontStack-monospace);">
            <%= @purchase_order.order_number.presence || "##{@purchase_order.id}" %>
          </h1>
          <% status_scheme = { "draft" => :secondary, "open" => :accent, "completed" => :success, "deleted" => :danger }[@purchase_order.status] || :secondary %>
          <%= render(Primer::Beta::Label.new(scheme: status_scheme, size: :large)) { @purchase_order.humanized_state } %>
        </div>
        <p style="color: var(--fgColor-muted, #656d76); margin: 0; font-size: 16px;"><%= @purchase_order.supplier_name %></p>
      </div>

      <div style="display: flex; gap: 8px;">
        <% if policy(@purchase_order).send_to_zenventory? && @purchase_order.may_mark_open? %>
          <%= form_with url: send_to_zenventory_warehouse_purchase_order_path(@purchase_order), method: :post, style: "display: inline;" do %>
            <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary, size: :medium) do |btn|
              btn.with_leading_visual_icon(icon: :upload)
              "Send to Zenventory"
            end %>
          <% end %>
        <% end %>
        <% if policy(@purchase_order).edit? %>
          <%= render Primer::Beta::Button.new(tag: :a, href: edit_warehouse_purchase_order_path(@purchase_order), scheme: :secondary, size: :medium) do |btn|
            btn.with_leading_visual_icon(icon: :pencil)
            "Edit"
          end %>
        <% end %>
        <% if @purchase_order.zenventory_url.present? %>
          <%= render Primer::Beta::Button.new(tag: :a, href: @purchase_order.zenventory_url, scheme: :secondary, size: :medium, target: "_blank") do |btn|
            btn.with_leading_visual_icon(icon: :"link-external")
            "Zenventory"
          end %>
        <% end %>
      </div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
    <div style="padding: 16px; text-align: center; background: var(--bgColor-muted); border: 1px solid var(--borderColor-default); border-radius: 6px;">
      <div style="font-size: 32px; font-weight: 700; line-height: 1;"><%= @purchase_order.line_items.sum(&:quantity) %></div>
      <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">Total Units</div>
    </div>
    <div style="padding: 16px; text-align: center; background: var(--bgColor-muted); border: 1px solid var(--borderColor-default); border-radius: 6px;">
      <div style="font-size: 32px; font-weight: 700; line-height: 1;"><%= number_to_currency(@purchase_order.total_cost) %></div>
      <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">Total Cost</div>
    </div>
    <div style="padding: 16px; text-align: center; background: var(--bgColor-muted); border: 1px solid var(--borderColor-default); border-radius: 6px;">
      <div style="font-size: 32px; font-weight: 700; line-height: 1;"><%= @purchase_order.line_items.count %></div>
      <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">Line Items</div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Supplier</span><span><%= @purchase_order.supplier_name %></span></div>
      <% end
      if @purchase_order.supplier_id.present?
        box.with_row do %>
          <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Supplier ID</span><code><%= @purchase_order.supplier_id %></code></div>
        <% end
      end
      if @purchase_order.required_by_date.present?
        box.with_row do %>
          <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Required By</span><span><%= @purchase_order.required_by_date.strftime("%B %d, %Y") %></span></div>
        <% end
      end
      if @purchase_order.notes.present?
        box.with_row do %>
          <div><div style="color: var(--fgColor-muted); margin-bottom: 4px;">Notes</div><div><%= simple_format(@purchase_order.notes) %></div></div>
        <% end
      end
    end %>

    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Created By</span><span><%= link_to @purchase_order.user&.email, @purchase_order.user, style: "color: var(--fgColor-accent);" %></span></div>
      <% end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Created At</span><span><%= @purchase_order.created_at.strftime("%B %d, %Y at %I:%M %p") %></span></div>
      <% end
      if @purchase_order.order_number.present?
        box.with_row do %>
          <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Order Number</span><code><%= @purchase_order.order_number %></code></div>
        <% end
      end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Zenventory ID</span><code><%= @purchase_order.zenventory_id || "—" %></code></div>
      <% end
    end %>
  </div>

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Line Items</h2>
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_header do %>
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
          <span style="font-weight: 600;">SKU</span>
          <div style="display: flex; gap: 48px;">
            <span style="font-weight: 600; min-width: 80px; text-align: right;">Quantity</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">Unit Cost</span>
            <span style="font-weight: 600; min-width: 100px; text-align: right;">Line Total</span>
          </div>
        </div>
      <% end

      @purchase_order.line_items.each do |li|
        box.with_row do %>
          <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
            <div>
              <%= link_to li.sku.name, warehouse_sku_path(li.sku), style: "color: var(--fgColor-accent); font-weight: 500;" %>
              <span style="color: var(--fgColor-muted); font-size: 13px; margin-left: 8px; font-family: var(--fontStack-monospace);"><%= li.sku.sku %></span>
            </div>
            <div style="display: flex; gap: 48px;">
              <span style="min-width: 80px; text-align: right; font-weight: 500;"><%= li.quantity %></span>
              <span style="min-width: 80px; text-align: right; color: var(--fgColor-muted);"><%= number_to_currency(li.unit_cost) %></span>
              <span style="min-width: 100px; text-align: right; font-weight: 500;"><%= number_to_currency((li.unit_cost || 0) * li.quantity) %></span>
            </div>
          </div>
        <% end
      end

      box.with_footer do %>
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
          <span style="font-weight: 600;">Total</span>
          <span style="font-weight: 700; font-size: 16px;"><%= number_to_currency(@purchase_order.total_cost) %></span>
        </div>
      <% end
    end %>
  </div>

  <div style="display: flex; gap: 8px; margin-bottom: 24px; padding-top: 16px; border-top: 1px solid var(--borderColor-muted);">
    <% if policy(@purchase_order).sync? %>
      <%= form_with url: sync_warehouse_purchase_order_path(@purchase_order), method: :post, style: "display: inline;" do %>
        <%= render Primer::Beta::Button.new(type: :submit, scheme: :secondary, size: :small) do |btn|
          btn.with_leading_visual_icon(icon: :sync)
          "Sync from Zenventory"
        end %>
      <% end %>
    <% end %>
    <% if @purchase_order.zenventory_id.present? %>
      <%= render Primer::Beta::Button.new(tag: :a, href: "https://app.zenventory.com/printing/printpurchaseorder.php?poid=#{@purchase_order.zenventory_id}", scheme: :secondary, size: :small, target: "_blank") do |btn|
        btn.with_leading_visual_icon(icon: :file)
        "Download PDF"
      end %>
    <% end %>
    <% if policy(@purchase_order).destroy? %>
      <%= form_with url: warehouse_purchase_order_path(@purchase_order), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this purchase order?" }, style: "display: inline;" do %>
        <%= render Primer::Beta::Button.new(type: :submit, scheme: :danger, size: :small) do |btn|
          btn.with_leading_visual_icon(icon: :trash)
          "Delete"
        end %>
      <% end %>
    <% end %>
  </div>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to Purchase Orders", warehouse_purchase_orders_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>

  <%= render partial: "admin_inspector", locals: { record: @purchase_order } %>
</div>
