<%= form_with(model: purchase_order, url: purchase_order.persisted? ? warehouse_purchase_order_path(purchase_order) : warehouse_purchase_orders_path) do |form| %>
  <% if purchase_order.errors.any? %>
    <%= render Primer::Beta::Flash.new(scheme: :danger, full: true, mb: 3) do %>
      <strong><%= pluralize(purchase_order.errors.count, "error") %> prevented saving:</strong>
      <ul class="error-list">
        <% purchase_order.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box| %>
    <% box.with_header do |header| %>
      <% header.with_title(tag: :h2) do %>Supplier Information<% end %>
    <% end %>
    <% box.with_body do %>
      <div class="form-grid-wide">
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "warehouse_purchase_order[supplier_name]",
            label: "Supplier name",
            value: purchase_order.supplier_name,
            full_width: true,
            required: true,
            placeholder: "Enter supplier name"
          ) %>
        </div>
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "warehouse_purchase_order[supplier_id]",
            label: "Supplier ID (optional)",
            value: purchase_order.supplier_id,
            full_width: true,
            placeholder: "Zenventory supplier ID"
          ) %>
        </div>
      </div>
      <div class="section-header">
        <label class="date-field-label">Required by date</label>
        <%= form.date_field :required_by_date, class: "date-field" %>
      </div>
      <%= render Primer::Alpha::TextArea.new(
        name: "warehouse_purchase_order[notes]",
        label: "Notes",
        value: purchase_order.notes,
        rows: 3,
        full_width: true,
        placeholder: "Add any notes for this purchase order..."
      ) %>
    <% end %>
  <% end %>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box| %>
    <% box.with_header do |header| %>
      <% header.with_title(tag: :h2) do %>Line Items<% end %>
    <% end %>
    <% box.with_body do %>
      <%= render Components::Warehouse::LineItemsEditor.new(
        form: form,
        scope: :enabled,
        show_unit_cost: true,
        add_button_text: "Add Item"
      ) %>
    <% end %>
  <% end %>

  <div class="page-actions">
    <%= render Primer::Beta::Button.new(tag: :a, href: warehouse_purchase_orders_path, scheme: :secondary) do
      "Cancel"
    end %>
    <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :check)
      purchase_order.persisted? ? "Update Purchase Order" : "Create Purchase Order"
    end %>
  </div>
<% end %>
