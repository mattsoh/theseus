<% content_for :title, "Purchase Orders" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <div>
      <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Purchase Orders</h1>
      <p style="color: var(--fgColor-muted); margin: 4px 0 0; font-size: 14px;">
        <%= @purchase_orders.count %> orders
      </p>
    </div>

    <%= render Primer::Beta::Button.new(tag: :a, href: new_warehouse_purchase_order_path, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :plus)
      "New Purchase Order"
    end %>
  </div>

  <% if @purchase_orders.any? %>
    <% grouped = @purchase_orders.group_by(&:status) %>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; margin-bottom: 24px;" id="stats-container">
      <% if grouped["draft"]&.any? %>
        <button class="stat-pill-filter" data-filter="draft" data-scheme="secondary" style="padding: 12px 16px; background: var(--bgColor-muted); border: 2px solid var(--borderColor-default); border-radius: 6px; text-align: center; cursor: pointer; transition: all 0.2s; font-family: inherit;">
          <div style="font-size: 24px; font-weight: 600; line-height: 1;"><%= grouped["draft"]&.count || 0 %></div>
          <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">Draft</div>
        </button>
      <% end %>
      <% if grouped["open"]&.any? %>
        <button class="stat-pill-filter" data-filter="open" data-scheme="accent" style="padding: 12px 16px; background: var(--bgColor-accent-muted, #ddf4ff); border: 2px solid var(--borderColor-accent-muted, #54aeff); border-radius: 6px; text-align: center; cursor: pointer; transition: all 0.2s; font-family: inherit;">
          <div style="font-size: 24px; font-weight: 600; line-height: 1;"><%= grouped["open"]&.count || 0 %></div>
          <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">Open</div>
        </button>
      <% end %>
      <% if grouped["completed"]&.any? %>
        <button class="stat-pill-filter" data-filter="completed" data-scheme="success" style="padding: 12px 16px; background: var(--bgColor-success-muted, #dafbe1); border: 2px solid var(--borderColor-success-muted, #aceebb); border-radius: 6px; text-align: center; cursor: pointer; transition: all 0.2s; font-family: inherit;">
          <div style="font-size: 24px; font-weight: 600; line-height: 1;"><%= grouped["completed"]&.count || 0 %></div>
          <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">Completed</div>
        </button>
      <% end %>
    </div>

    <%= render Primer::Beta::BorderBox.new do |box|
      @purchase_orders.each do |po|
        status_scheme = { "draft" => :secondary, "open" => :accent, "completed" => :success, "deleted" => :danger }[po.status] || :secondary
        box.with_row(classes: "po-row", data: { status: po.status }) do %>
          <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px;">
            <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0;">
              <%= link_to po.order_number.presence || "##{po.id}", warehouse_purchase_order_path(po), style: "font-family: var(--fontStack-monospace); color: var(--fgColor-accent); font-weight: 500;" %>
              <%= render(Primer::Beta::Label.new(scheme: status_scheme, size: :medium)) { po.humanized_state } %>
              <span style="color: var(--fgColor-muted); font-size: 13px;"><%= po.supplier_name %></span>
            </div>
            <div style="display: flex; align-items: center; gap: 16px;">
              <div style="text-align: right; min-width: 100px;">
                <div style="font-weight: 500;"><%= po.line_items.sum(&:quantity) %> units</div>
                <div style="font-size: 12px; color: var(--fgColor-muted);"><%= number_to_currency(po.total_cost) %></div>
              </div>
              <% if po.required_by_date.present? %>
                <div style="text-align: right; min-width: 100px;">
                  <div style="font-size: 12px; color: var(--fgColor-muted);">Required by</div>
                  <div style="font-size: 13px;"><%= po.required_by_date.strftime("%b %d, %Y") %></div>
                </div>
              <% end %>
              <div style="text-align: right; min-width: 80px; color: var(--fgColor-muted); font-size: 13px;">
                <%= time_ago_in_words(po.created_at) %> ago
              </div>
              <% admin_tool do %>
              <%= render Primer::Alpha::ActionMenu.new do |menu|
                menu.with_show_button(icon: :"kebab-horizontal", "aria-label": "Actions", scheme: :invisible)
                menu.with_item(label: "View", href: warehouse_purchase_order_path(po)) do |item|
                  item.with_leading_visual_icon(icon: :eye)
                end
                if po.draft?
                  menu.with_item(label: "Edit", href: edit_warehouse_purchase_order_path(po)) do |item|
                    item.with_leading_visual_icon(icon: :pencil)
                  end
                end
                if po.zenventory_id.present?
                  menu.with_item(label: "Zenventory", href: po.zenventory_url, content_arguments: { target: "_blank" }) do |item|
                    item.with_leading_visual_icon(icon: :"link-external")
                  end
                  menu.with_item(label: "Zenv PDF", href: "https://app.zenventory.com/printing/printpurchaseorder.php?poid=#{po.zenventory_id}", content_arguments: { target: "_blank" }) do |item|
                    item.with_leading_visual_icon(icon: :file)
                  end
                end
              end %>
            </div>
          </div>
        <% end
      end
           end
    end %>
  <% else %>
    <div style="border: 1px solid var(--borderColor-default); border-radius: 6px;">
      <%= render Primer::Beta::Blankslate.new do |bs|
        bs.with_visual_icon(icon: :archive)
        bs.with_heading(tag: :h3) { "No purchase orders yet" }
        bs.with_description { "Create your first purchase order to get started." }
        bs.with_primary_action(href: new_warehouse_purchase_order_path) { "Create Purchase Order" }
      end %>
    </div>
  <% end %>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to SKUs", warehouse_skus_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>

<script>
(function() {
  let selectedStatus = null;

  const bgColors = {
    secondary: 'var(--bgColor-muted)',
    accent: 'var(--bgColor-accent-muted)',
    success: 'var(--bgColor-success-muted)',
    danger: 'var(--bgColor-danger-muted)'
  };
  const borderColors = {
    secondary: 'var(--borderColor-default)',
    accent: 'var(--borderColor-accent-muted)',
    success: 'var(--borderColor-success-muted)',
    danger: 'var(--borderColor-danger-muted)'
  };

  function getStatPills() {
    return document.querySelectorAll('.stat-pill-filter');
  }

  function getRows() {
    return document.querySelectorAll('.po-row');
  }

  function resetPill(pill) {
    const scheme = pill.dataset.scheme;
    pill.style.background = bgColors[scheme];
    pill.style.borderColor = borderColors[scheme];
    pill.style.boxShadow = 'none';
  }

  function setActivePill(pill) {
    const scheme = pill.dataset.scheme;
    pill.style.borderColor = 'var(--fgColor-default)';
    pill.style.boxShadow = '0 0 0 1px var(--fgColor-default)';
  }

  function updateDisplay() {
    getRows().forEach(row => {
      const status = row.dataset.status;
      const matchesStatus = !selectedStatus || status === selectedStatus;
      row.style.display = matchesStatus ? '' : 'none';
    });
  }

  document.addEventListener('click', function(e) {
    const pill = e.target.closest('.stat-pill-filter');
    if (pill) {
      const filter = pill.dataset.filter;
      if (selectedStatus === filter) {
        selectedStatus = null;
        resetPill(pill);
      } else {
        getStatPills().forEach(p => {
          if (p.dataset.filter !== filter) {
            resetPill(p);
          }
        });
        selectedStatus = filter;
        setActivePill(pill);
      }
      updateDisplay();
    }
  });
})();
</script>
