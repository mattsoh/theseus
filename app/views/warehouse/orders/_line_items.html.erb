<%= render Primer::Beta::BorderBox.new do |box|
  box.with_header do %>
    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
      <span style="font-weight: 600;">SKU</span>
      <div style="display: flex; gap: 48px;">
        <span style="font-weight: 600; min-width: 60px; text-align: right;">Qty</span>
        <span style="font-weight: 600; min-width: 90px; text-align: right;">Cost to HC</span>
        <span style="font-weight: 600; min-width: 90px; text-align: right;">Declared</span>
      </div>
    </div>
  <% end

  order.line_items.each do |li|
    box.with_row do %>
      <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
        <div>
          <%= link_to li.sku.name, warehouse_sku_path(li.sku), style: "color: var(--fgColor-accent); font-weight: 500;" %>
          <span style="color: var(--fgColor-muted); font-size: 13px; margin-left: 8px; font-family: var(--fontStack-monospace);"><%= li.sku.sku %></span>
        </div>
        <div style="display: flex; gap: 48px;">
          <span style="min-width: 60px; text-align: right; font-weight: 500;"><%= li.quantity %></span>
          <span style="min-width: 90px; text-align: right; color: var(--fgColor-muted);"><%= number_to_currency(li.sku.actual_cost_to_hc) %></span>
          <span style="min-width: 90px; text-align: right; color: var(--fgColor-muted);">
            <% if li.sku.declared_unit_cost.zero? %>
              <span style="color: var(--fgColor-danger); font-weight: 600;" title="This SKU has no cost data! It will block dispatch."><%= render Primer::Beta::Octicon.new(icon: :alert, size: :small) %> $0.00</span>
            <% else %>
              <%= number_to_currency(li.sku.declared_unit_cost) %>
            <% end %>
          </span>
        </div>
      </div>
    <% end
  end

  box.with_footer do %>
    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
      <span style="font-weight: 600;">Total</span>
      <div style="display: flex; gap: 48px;">
        <span style="min-width: 60px;"></span>
        <span style="min-width: 90px; text-align: right; font-weight: 600;"><%= number_to_currency(order.contents_actual_cost_to_hc) %></span>
        <span style="min-width: 90px; text-align: right; font-weight: 600;"><%= number_to_currency(order.contents_declared_unit_cost) %></span>
      </div>
    </div>
  <% end
end %>
