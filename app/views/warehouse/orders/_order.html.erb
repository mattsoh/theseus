<div class="index-card">
  <div class="index-card-header">
    <div class="page-title-group">
      <a href="<%= warehouse_order_path(order) %>" class="mono index-card-title"><%= order.hc_id %></a>
      <% if order.user_facing_title.present? %>
        <span>·</span>
        <span><%= order.user_facing_title %></span>
      <% end %>
    </div>
    <%= render 'warehouse/orders/status_badge', order: order %>
  </div>

  <% if order.tags.present? %>
    <div class="tags-row">
      <% order.tags.compact_blank.each do |tag| %>
        <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :small)) { tag } %>
      <% end %>
    </div>
  <% end %>

  <div class="detail-grid">
    <div>
      <div class="detail-label">Recipient</div>
      <div class="fw-medium"><%= order.address&.name_line || "—" %></div>
      <div class="resource-card-meta"><%= order.recipient_email %></div>
    </div>
    <div>
      <div class="detail-label">Cost</div>
      <div>
        <span class="kv-label">Labor:</span> <%= number_to_currency(order.labor_cost) %>
        <span class="kv-label">Contents:</span> <%= number_to_currency(order.contents_actual_cost_to_hc) %>
        <span class="kv-label">Postage:</span> <%= order.postage_cost.present? ? number_to_currency(order.postage_cost) : "—" %>
      </div>
    </div>
  </div>
</div>
