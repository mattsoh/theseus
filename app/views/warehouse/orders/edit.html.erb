<% content_for :title, "Edit order #{@warehouse_order.hc_id}" %>

<div style="max-width: 800px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
    <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Edit order</h1>
    <code style="font-size: 16px; color: var(--fgColor-accent);"><%= @warehouse_order.hc_id %></code>
  </div>

  <%= render "form", warehouse_order: @warehouse_order %>

  <div style="margin-top: 32px; display: flex; gap: 16px;">
    <%= link_to "← Back to order", warehouse_order_path(@warehouse_order), style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
