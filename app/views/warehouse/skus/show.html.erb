<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="margin-bottom: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 16px;">
      <div>
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
          <h1 style="font-size: 24px; font-weight: 600; margin: 0; font-family: var(--fontStack-monospace);"><%= @warehouse_sku.sku %></h1>
          <% if @warehouse_sku.in_stock.to_i > 10 %>
            <%= render(Primer::Beta::Label.new(scheme: :success, size: :large)) { "In stock" } %>
          <% elsif @warehouse_sku.in_stock.to_i.between?(1, 10) %>
            <%= render(Primer::Beta::Label.new(scheme: :attention, size: :large)) { "Low stock" } %>
          <% elsif @warehouse_sku.in_stock.to_i < 0 %>
            <% if @warehouse_sku.inbound.to_i >= @warehouse_sku.in_stock.abs %>
              <%= render(Primer::Beta::Label.new(scheme: :attention, size: :large)) { "Backordered" } %>
            <% else %>
              <%= render(Primer::Beta::Label.new(scheme: :danger, size: :large)) { "Backordered (!)" } %>
            <% end %>
          <% else %>
            <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :large)) { "No inventory" } %>
          <% end %>
          <% if @warehouse_sku.ai_enabled %>
            <%= render(Primer::Beta::Label.new(scheme: :accent, size: :large)) { "AI" } %>
          <% end %>
          <% unless @warehouse_sku.enabled %>
            <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :large)) { "Disabled" } %>
          <% end %>
        </div>
        <p style="color: var(--fgColor-muted, #656d76); margin: 0; font-size: 16px;"><%= @warehouse_sku.name %></p>
      </div>

      <div style="display: flex; gap: 8px;">
        <% admin_tool do %>
          <%= render Primer::Beta::Button.new(tag: :a, href: edit_admin_warehouse_sku_path(@warehouse_sku), scheme: :primary, size: :medium) do |btn|
            btn.with_leading_visual_icon(icon: :pencil)
            "Edit"
          end %>
        <% end %>
        <% if @warehouse_sku.zenventory_url.present? %>
          <% admin_tool do %>
            <%= render Primer::Beta::Button.new(tag: :a, href: @warehouse_sku.zenventory_url, scheme: :secondary, size: :medium, target: "_blank") do |btn|
              btn.with_leading_visual_icon(icon: :"link-external")
              "Zenventory"
            end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
    <div style="padding: 16px; text-align: center; background: var(--bgColor-success-muted); border: 1px solid var(--borderColor-success-muted); border-radius: 6px;">
      <div style="font-size: 32px; font-weight: 700; line-height: 1;"><%= @warehouse_sku.in_stock || "—" %></div>
      <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">In Stock</div>
    </div>
    <div style="padding: 16px; text-align: center; background: var(--bgColor-attention-muted); border: 1px solid var(--borderColor-attention-muted); border-radius: 6px;">
      <div style="font-size: 32px; font-weight: 700; line-height: 1;"><%= @warehouse_sku.inbound || "—" %></div>
      <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">Inbound</div>
    </div>
    <div style="padding: 16px; text-align: center; background: var(--bgColor-muted); border: 1px solid var(--borderColor-default); border-radius: 6px;">
      <div style="font-size: 32px; font-weight: 700; line-height: 1;"><%= number_to_currency(@warehouse_sku.declared_unit_cost) %></div>
      <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.3px;">Unit Cost</div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Category</span><span><%= @warehouse_sku.category&.humanize || "—" %></span></div>
      <% end
      if @warehouse_sku.description.present?
        box.with_row do %>
          <div><div style="color: var(--fgColor-muted); margin-bottom: 4px;">Description</div><div><%= @warehouse_sku.description %></div></div>
        <% end
      end
      if @warehouse_sku.customs_description.present?
        box.with_row do %>
          <div><div style="color: var(--fgColor-muted); margin-bottom: 4px;">Customs</div><div><%= @warehouse_sku.customs_description %></div></div>
        <% end
      end
    end %>

    <%= render Primer::Beta::BorderBox.new do |box|
      if @warehouse_sku.country_of_origin.present?
        box.with_row do %>
          <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Country of Origin</span><span><%= @warehouse_sku.country_of_origin %></span></div>
        <% end
      end
      if @warehouse_sku.hs_code.present?
        box.with_row do %>
          <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">HS Code</span><code><%= @warehouse_sku.hs_code %></code></div>
        <% end
      end
      if @warehouse_sku.average_po_cost.present?
        box.with_row do %>
          <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Avg PO Cost</span><span><%= number_to_currency(@warehouse_sku.average_po_cost) %></span></div>
        <% end
      end
      if @warehouse_sku.actual_cost_to_hc.present?
        box.with_row do %>
          <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Actual Cost to HC</span><span><%= number_to_currency(@warehouse_sku.actual_cost_to_hc) %></span></div>
        <% end
      end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Zenventory ID</span><code><%= @warehouse_sku.zenventory_id || "—" %></code></div>
      <% end
    end %>
  </div>

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Recent Orders</h2>
    <% if @recent_orders.any? %>
      <%= render Primer::Beta::BorderBox.new do |box|
        @recent_orders.each do |order|
          line_item = order.line_items.find_by(sku_id: @warehouse_sku.id)
          box.with_row do %>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px;">
              <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0;">
                <%= link_to order.hc_id, warehouse_order_path(order), style: "font-family: var(--fontStack-monospace); color: var(--fgColor-accent); font-weight: 500;" %>
                <% status_scheme = { "draft" => :secondary, "dispatched" => :accent, "mailed" => :success, "canceled" => :danger, "errored" => :danger }[order.aasm_state] || :secondary %>
                <%= render(Primer::Beta::Label.new(scheme: status_scheme, size: :medium)) { order.humanized_state } %>
                <span style="color: var(--fgColor-muted); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;" title="<%= order.address&.name_line %>"><%= order.address&.name_line %></span>
              </div>
              <div style="display: flex; align-items: center; gap: 16px;">
                <div style="text-align: right; min-width: 80px;">
                  <div style="font-weight: 500;"><%= line_item&.quantity || 0 %> units</div>
                </div>
                <% if order.tracking_number.present? %>
                  <div style="min-width: 100px;">
                    <%= link_to order.tracking_url, target: "_blank", style: "font-size: 12px; color: var(--fgColor-accent);" do %>
                      <%= order.pretty_via %> ↗
                    <% end %>
                  </div>
                <% else %>
                  <div style="min-width: 100px; font-size: 12px; color: var(--fgColor-muted);">No tracking</div>
                <% end %>
                <div style="text-align: right; min-width: 80px; color: var(--fgColor-muted); font-size: 13px;">
                  <%= time_ago_in_words(order.created_at) %> ago
                </div>
                <% admin_tool do %>
                  <%= render Primer::Alpha::ActionMenu.new do |menu|
                    menu.with_show_button(icon: :"kebab-horizontal", "aria-label": "Actions", scheme: :invisible)
                    menu.with_item(label: "View", href: warehouse_order_path(order)) do |item|
                      item.with_leading_visual_icon(icon: :eye)
                    end
                    unless order.mailed? || order.canceled?
                      menu.with_item(label: "Edit", href: edit_warehouse_order_path(order)) do |item|
                        item.with_leading_visual_icon(icon: :pencil)
                      end
                    end
                    if order.zenventory_url.present?
                      menu.with_item(label: "Zenventory", href: order.zenventory_url, content_arguments: { target: "_blank" }) do |item|
                        item.with_leading_visual_icon(icon: :"link-external")
                      end
                    end
                    if order.tracking_url.present?
                      menu.with_item(label: "Track Package", href: order.tracking_url, content_arguments: { target: "_blank" }) do |item|
                        item.with_leading_visual_icon(icon: :location)
                      end
                    end
                  end %>
                <% end %>
              </div>
            </div>
          <% end
        end
      end %>
    <% else %>
      <div style="border: 1px solid var(--borderColor-default); border-radius: 6px;">
        <%= render Primer::Beta::Blankslate.new do |bs|
          bs.with_visual_icon(icon: :package)
          bs.with_heading(tag: :h3) { "No orders yet" }
          bs.with_description { "Theseus orders containing this SKU will appear here." }
        end %>
      </div>
    <% end %>
  </div>

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Purchase Orders</h2>
    <% if @recent_purchase_orders.any? %>
      <%= render Primer::Beta::BorderBox.new do |box|
        @recent_purchase_orders.each do |po|
          line_item = po.line_items.find_by(sku_id: @warehouse_sku.id)
          box.with_row do %>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 16px;">
              <div style="display: flex; align-items: center; gap: 12px; flex: 1; min-width: 0;">
                <%= link_to po.order_number.presence || "##{po.id}", warehouse_purchase_order_path(po), style: "font-family: var(--fontStack-monospace); color: var(--fgColor-accent); font-weight: 500;" %>
                <% status_scheme = { "draft" => :secondary, "open" => :accent, "completed" => :success, "deleted" => :danger }[po.status] || :secondary %>
                <%= render(Primer::Beta::Label.new(scheme: status_scheme, size: :medium)) { po.humanized_state } %>
                <span style="color: var(--fgColor-muted); font-size: 13px;"><%= po.supplier_name %></span>
              </div>
              <div style="display: flex; align-items: center; gap: 16px;">
                <div style="text-align: right; min-width: 100px;">
                  <div style="font-weight: 500;"><%= line_item&.quantity || 0 %> units</div>
                  <div style="font-size: 12px; color: var(--fgColor-muted);"><%= number_to_currency(line_item&.unit_cost) %>/ea</div>
                </div>
                <div style="text-align: right; min-width: 80px; color: var(--fgColor-muted); font-size: 13px;">
                  <%= time_ago_in_words(po.created_at) %> ago
                </div>
                <% admin_tool do %>
                  <%= render Primer::Alpha::ActionMenu.new do |menu|
                    menu.with_show_button(icon: :"kebab-horizontal", "aria-label": "Actions", scheme: :invisible)
                    menu.with_item(label: "View", href: warehouse_purchase_order_path(po)) do |item|
                      item.with_leading_visual_icon(icon: :eye)
                    end
                    unless po.completed?
                      menu.with_item(label: "Edit", href: edit_warehouse_purchase_order_path(po)) do |item|
                        item.with_leading_visual_icon(icon: :pencil)
                      end
                    end
                    if po.zenventory_id.present?
                      menu.with_item(label: "Zenv PDF", href: "https://app.zenventory.com/printing/printpurchaseorder.php?poid=#{po.zenventory_id}", content_arguments: { target: "_blank" }) do |item|
                        item.with_leading_visual_icon(icon: :"file")
                      end
                    end
                  end %>
                <% end %>
              </div>
            </div>
          <% end
        end
      end %>
    <% else %>
      <div style="border: 1px solid var(--borderColor-default); border-radius: 6px;">
        <%= render Primer::Beta::Blankslate.new do |bs|
          bs.with_visual_icon(icon: :archive)
          bs.with_heading(tag: :h3) { "No purchase orders yet" }
          bs.with_description { "Purchase orders for this SKU will appear here." }
        end %>
      </div>
    <% end %>
  </div>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to SKUs", warehouse_skus_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>

  <%= render partial: "admin_inspector", locals: { record: @warehouse_sku } %>
</div>
