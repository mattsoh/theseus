<div style="padding: 16px; border: 1px solid var(--borderColor-default); border-radius: 6px; margin-bottom: 12px;">
  <div style="display: flex; justify-content: space-between; align-items: flex-start;">
    <div>
      <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
        <a href="<%= warehouse_sku_path(sku) %>" style="font-weight: 600; font-family: var(--fontStack-monospace); color: var(--fgColor-accent); text-decoration: none;"><%= sku.sku %></a>
        <% if sku.in_stock.to_i > 0 %>
          <%= render(Primer::Beta::Label.new(scheme: :success, size: :small)) { "In stock" } %>
        <% elsif sku.in_stock.to_i < 0 %>
          <% if sku.inbound.to_i >= sku.in_stock.abs %>
            <%= render(Primer::Beta::Label.new(scheme: :attention, size: :small)) { "Backordered" } %>
          <% else %>
            <%= render(Primer::Beta::Label.new(scheme: :danger, size: :small)) { "Backordered (!)" } %>
          <% end %>
        <% else %>
          <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :small)) { "No inventory" } %>
        <% end %>
        <% if sku.ai_enabled %>
          <%= render(Primer::Beta::Label.new(scheme: :accent, size: :small)) { "AI" } %>
        <% end %>
        <% unless sku.enabled %>
          <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :small)) { "Disabled" } %>
        <% end %>
      </div>
      <div style="font-size: 14px; color: var(--fgColor-default);"><%= sku.name %></div>
      <% if sku.description.present? %>
        <div style="font-size: 13px; color: var(--fgColor-muted); margin-top: 2px;"><%= truncate(sku.description, length: 80) %></div>
      <% end %>
    </div>
    <div style="display: flex; gap: 24px; text-align: right;">
      <div>
        <div style="font-weight: 600;"><%= sku.in_stock || "—" %></div>
        <div style="font-size: 12px; color: var(--fgColor-muted);">in stock</div>
      </div>
      <div>
        <div style="font-weight: 600;">
          <% if sku.declared_unit_cost.zero? %>
            <span style="color: var(--fgColor-danger);" title="No cost data — will block dispatch"><%= render Primer::Beta::Octicon.new(icon: :alert, size: :small) %> $0.00</span>
          <% else %>
            <%= number_to_currency(sku.declared_unit_cost) %>
          <% end %>
        </div>
        <div style="font-size: 12px; color: var(--fgColor-muted);">unit cost</div>
      </div>
    </div>
  </div>
</div>
