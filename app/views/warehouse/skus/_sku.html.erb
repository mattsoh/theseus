<div class="sku-card">
  <div class="sku-card-layout">
    <div>
      <div class="page-title-group">
        <a href="<%= warehouse_sku_path(sku) %>" class="mono fw-semibold"><%= sku.sku %></a>
        <% if sku.in_stock.to_i > 0 %>
          <%= render(Primer::Beta::Label.new(scheme: :success, size: :small)) { "In stock" } %>
        <% elsif sku.in_stock.to_i < 0 %>
          <% if sku.inbound.to_i >= sku.in_stock.abs %>
            <%= render(Primer::Beta::Label.new(scheme: :attention, size: :small)) { "Backordered" } %>
          <% else %>
            <%= render(Primer::Beta::Label.new(scheme: :danger, size: :small)) { "Backordered (!)" } %>
          <% end %>
        <% else %>
          <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :small)) { "No inventory" } %>
        <% end %>
        <% if sku.ai_enabled %>
          <%= render(Primer::Beta::Label.new(scheme: :accent, size: :small)) { "AI" } %>
        <% end %>
        <% unless sku.enabled %>
          <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :small)) { "Disabled" } %>
        <% end %>
      </div>
      <div><%= sku.name %></div>
      <% if sku.description.present? %>
        <div class="resource-card-meta"><%= truncate(sku.description, length: 80) %></div>
      <% end %>
    </div>
    <div class="sku-card-stats">
      <div>
        <div class="fw-semibold"><%= sku.in_stock || "—" %></div>
        <div class="resource-card-meta">in stock</div>
      </div>
      <div>
        <div class="fw-semibold">
          <% if sku.declared_unit_cost.zero? %>
            <span class="text-danger" title="No cost data — will block dispatch"><%= render Primer::Beta::Octicon.new(icon: :alert, size: :small) %> $0.00</span>
          <% else %>
            <%= number_to_currency(sku.declared_unit_cost) %>
          <% end %>
        </div>
        <div class="resource-card-meta">unit cost</div>
      </div>
    </div>
  </div>
</div>
