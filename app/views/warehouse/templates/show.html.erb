<% content_for :title, @warehouse_template.name %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;">
    <div>
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
        <h1 style="font-size: 24px; font-weight: 600; margin: 0;"><%= @warehouse_template.name %></h1>
        <% if @warehouse_template.public %>
          <%= render(Primer::Beta::Label.new(scheme: :accent, size: :large)) { "Shared" } %>
        <% end %>
      </div>
      <p style="color: var(--fgColor-muted); margin: 0; font-size: 14px;">
        Created by <%= @warehouse_template.user&.username || "unknown" %>
        · API ID: <%= render Components::Shared::PublicId.new(value: @warehouse_template.public_id) %>
      </p>
    </div>

    <div style="display: flex; gap: 8px;">
      <%= render Primer::Beta::Button.new(tag: :a, href: edit_warehouse_template_path(@warehouse_template), scheme: :secondary, size: :medium) do |btn|
        btn.with_leading_visual_icon(icon: :pencil)
        "Edit"
      end %>
    </div>
  </div>

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Contents</h2>
    <%= render 'warehouse/orders/line_items', order: @warehouse_template %>
  </div>

  <div style="display: flex; gap: 8px; padding-top: 16px; border-top: 1px solid var(--borderColor-muted); margin-bottom: 24px;">
    <%= form_with url: warehouse_template_path(@warehouse_template), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this template?" }, style: "display: inline;" do %>
      <%= render Primer::Beta::Button.new(type: :submit, scheme: :danger, size: :small) do |btn|
        btn.with_leading_visual_icon(icon: :trash)
        "Delete template"
      end %>
    <% end %>
  </div>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to templates", warehouse_templates_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
