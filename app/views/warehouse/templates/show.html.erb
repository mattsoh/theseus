<% content_for :title, @warehouse_template.name %>

<div class="page-container">
  <div class="page-header">
    <div>
      <div class="page-title-group">
        <h1 class="page-title"><%= @warehouse_template.name %></h1>
        <% if @warehouse_template.public %>
          <%= render(Primer::Beta::Label.new(scheme: :accent, size: :large)) { "Shared" } %>
        <% end %>
      </div>
      <p class="page-subtitle">
        Created by <%= @warehouse_template.user&.username || "unknown" %>
        · API ID: <%= render Components::Shared::PublicId.new(value: @warehouse_template.public_id) %>
      </p>
    </div>

    <div class="page-actions">
      <%= render Primer::Beta::Button.new(tag: :a, href: edit_warehouse_template_path(@warehouse_template), scheme: :secondary, size: :medium) do |btn|
        btn.with_leading_visual_icon(icon: :pencil)
        "Edit"
      end %>
    </div>
  </div>

  <div style="margin-bottom: 24px;">
    <h2 class="section-heading">Contents</h2>
    <%= render 'warehouse/orders/line_items', order: @warehouse_template %>
  </div>

  <div class="footer-actions">
    <%= form_with url: warehouse_template_path(@warehouse_template), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this template?" }, style: "display: inline;" do %>
      <%= render Primer::Beta::Button.new(type: :submit, scheme: :danger, size: :small) do |btn|
        btn.with_leading_visual_icon(icon: :trash)
        "Delete template"
      end %>
    <% end %>
  </div>

  <div style="margin-top: 32px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: warehouse_templates_path, scheme: :invisible, size: :small) do |btn|
      btn.with_leading_visual_icon(icon: :"arrow-left")
      "Back to templates"
    end %>
  </div>
</div>
