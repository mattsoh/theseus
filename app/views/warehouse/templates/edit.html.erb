<% content_for :title, "Edit Template" %>

<div class="page-container--narrow">
  <div class="page-title-group" style="margin-bottom: 24px;">
    <h1 class="page-title">Edit Template</h1>
    <span class="kv-label"><%= @warehouse_template.name %></span>
  </div>

  <%= render "form", warehouse_template: @warehouse_template %>

  <div style="margin-top: 32px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: warehouse_template_path(@warehouse_template), scheme: :invisible, size: :small) do |btn|
      btn.with_leading_visual_icon(icon: :"arrow-left")
      "Back to template"
    end %>
  </div>
</div>
