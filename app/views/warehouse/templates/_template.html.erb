<div class="sku-card">
  <div class="sku-card-layout">
    <div>
      <div class="section-title-group">
        <a href="<%= warehouse_template_path(template) %>" class="index-card-title"><%= template.name %></a>
        <% if template.public %>
          <%= render(Primer::Beta::Label.new(scheme: :accent, size: :small)) { "Shared" } %>
        <% end %>
      </div>
      <div class="resource-card-meta">
        by <%= template.user&.username || "unknown" %> · <%= template.line_items.count %> items
      </div>
    </div>
    <%= render Components::Shared::PublicId.new(value: template.public_id) %>
  </div>
</div>
