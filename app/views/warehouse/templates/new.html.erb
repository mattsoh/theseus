<% content_for :title, "New Template" %>

<div class="page-container--narrow">
  <h1 class="page-title" style="margin-bottom: 24px;">New Template</h1>

  <%= render "form", warehouse_template: @warehouse_template %>

  <div style="margin-top: 32px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: warehouse_templates_path, scheme: :invisible, size: :small) do |btn|
