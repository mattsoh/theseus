<% content_for :head do %>
  <%= vite_javascript_tag "taggable" %>
<% end %>
<%# Tag picker partial that can be used for any taggable model %>
<%# Usage: render 'shared/tag_picker', form: form, field_name: :tags %>
<% field_name ||= :tags %>
<% selected_tags = form.object.try(:tags) || [] %>
<% all_tags = available_tags(selected_tags) %>

<div class="FormControl mb-3">
  <%= form.label field_name, "Tags", class: "FormControl-label" %>
  <%= form.select field_name,
                  all_tags,
                  { selected: selected_tags, include_blank: false },
                  { multiple: true,
                    class: "selectize-tags width-full",
                    data: {
                      selectize: {
                        plugins: ['remove_button'],
                        persist: false,
                        create: true,
                        maxItems: nil
                      }
                    }
                  } %>
  <p class="FormControl-caption">Select from common tags or create your own</p>
</div>