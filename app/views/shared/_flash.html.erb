<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <% scheme = case type.to_sym
     when :success then :success
     when :notice, :info then :default
     when :warning then :warning
     when :alert, :error, :danger then :danger
     else :default
     end %>
  <%= render Primer::Beta::Flash.new(scheme: scheme, mb: 3, dismissible: true, full: true) do %>
    <%= message %>
  <% end %>
<% end %>
