<% content_for :title, "Edit Source Tag" %>

<div style="max-width: 600px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
    <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Edit Source Tag</h1>
    <code style="color: var(--fgColor-muted);"><%= @source_tag.slug %></code>
  </div>

  <%= render "form", source_tag: @source_tag %>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to source tag", source_tag_path(@source_tag), style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
