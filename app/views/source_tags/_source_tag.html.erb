<div style="padding: 12px 16px; border: 1px solid var(--borderColor-default); border-radius: 6px; margin-bottom: 8px;">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <div>
      <a href="<%= source_tag_path(source_tag) %>" style="font-weight: 600; color: var(--fgColor-accent); text-decoration: none;"><%= source_tag.name %></a>
      <code style="margin-left: 8px; font-size: 13px; color: var(--fgColor-muted);"><%= source_tag.slug %></code>
    </div>
    <% if source_tag.owner.present? %>
      <span style="font-size: 13px; color: var(--fgColor-muted);"><%= source_tag.owner %></span>
    <% end %>
  </div>
</div>
