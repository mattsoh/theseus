<% content_for :title, "Source Tags" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <div>
      <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Source Tags</h1>
      <p style="color: var(--fgColor-muted); margin: 4px 0 0; font-size: 14px;"><%= @source_tags.count %> source tags</p>
    </div>
    <%= render Primer::Beta::Button.new(tag: :a, href: new_source_tag_path, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :plus)
      "New Source Tag"
    end %>
  </div>

  <% if @source_tags.any? %>
    <%= render Primer::Beta::BorderBox.new do |box|
      @source_tags.each do |source_tag|
        box.with_row do %>
          <a href="<%= source_tag_path(source_tag) %>" style="display: flex; justify-content: space-between; align-items: center; width: 100%; text-decoration: none; color: inherit;">
            <div>
              <span style="font-weight: 600;"><%= source_tag.name %></span>
              <code style="margin-left: 8px; font-size: 13px; color: var(--fgColor-muted);"><%= source_tag.slug %></code>
            </div>
            <% if source_tag.owner.present? %>
              <span style="font-size: 13px; color: var(--fgColor-muted);"><%= source_tag.owner %></span>
            <% end %>
          </a>
        <% end
      end
    end %>
  <% else %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :tag)
      bs.with_heading(tag: :h3) { "No source tags yet" }
      bs.with_primary_action(href: new_source_tag_path) { "Create one" }
    end %>
  <% end %>
</div>
