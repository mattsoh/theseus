<% content_for :title, "New Letter" %>

<%= render Primer::Beta::Heading.new(tag: :h1, mb: 4) { "New Letter" } %>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start;">
  <div>
    <%= render "form", letter: @letter %>
  </div>

  <div style="position: sticky; top: 24px;">
    <%= render Primer::Beta::BorderBox.new(mb: 3) do |box| %>
      <% box.with_header do |header| %>
        <% header.with_title(tag: :h3) do %>Postage Rates<% end %>
      <% end %>
      <% box.with_body do %>
        <p class="f6 text-bold mb-1">Letters (stamps)</p>
        <table class="f6 mb-3" style="border-collapse: collapse;">
          <% USPS::PricingEngine::US_STAMP_LETTER_RATES.first(4).each do |oz, price| %>
            <tr>
              <td class="color-fg-muted pr-3"><%= oz == oz.to_i ? "#{oz.to_i} oz" : "#{oz} oz" %></td>
              <td style="font-family: var(--fontStack-monospace);"><%= number_to_currency(price) %></td>
            </tr>
          <% end %>
        </table>

        <p class="f6 text-bold mb-1">Flats (stamps)</p>
        <table class="f6 mb-3" style="border-collapse: collapse;">
          <% USPS::PricingEngine::US_STAMP_FLAT_RATES.first(3).each do |oz, price| %>
            <tr>
              <td class="color-fg-muted pr-3"><%= oz == oz.to_i ? "#{oz.to_i} oz" : "#{oz} oz" %></td>
              <td style="font-family: var(--fontStack-monospace);"><%= number_to_currency(price) %></td>
            </tr>
          <% end %>
        </table>

        <p class="f6 color-fg-muted mb-1">Non-machinable surcharge: +<%= number_to_currency(USPS::PricingEngine::FCMI_NON_MACHINABLE_SURCHARGE) %></p>
        <p class="f6 color-fg-muted">Indicia is slightly cheaper for standard letters.</p>
      <% end %>
    <% end %>

    <%= render Primer::Beta::BorderBox.new do |box| %>
      <% box.with_header do |header| %>
        <% header.with_title(tag: :h3) do %>Size Limits<% end %>
      <% end %>
      <% box.with_body do %>
        <dl class="f6">
          <dt class="text-bold">Letter</dt>
          <dd class="color-fg-muted mb-2">Up to 11.5 &times; 6.125 in, 3.5 oz</dd>
          <dt class="text-bold">Flat</dt>
          <dd class="color-fg-muted">Up to 15 &times; 12 in, 13 oz</dd>
        </dl>
      <% end %>
    <% end %>
  </div>
</div>

<div class="mt-4">
  <%= render Primer::Beta::Link.new(href: letters_path, muted: true) do |link| %>
    <% link.with_leading_visual_icon(icon: :"arrow-left") %>
    Back to letters
  <% end %>
</div>
