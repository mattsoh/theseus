<% content_for :title, "Buy Indicia - #{@letter.public_id}" %>

<div style="max-width: 600px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 24px 0;">Buy Indicia</h1>

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Letter Details</h2>
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_row do %>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; font-size: 14px;">
          <div>
            <div style="color: var(--fgColor-muted); font-size: 12px;">Recipient</div>
            <div style="font-weight: 500;"><%= @letter.address.name_line %></div>
          </div>
          <div>
            <div style="color: var(--fgColor-muted); font-size: 12px;">Destination</div>
            <div><%= @letter.address.city %>, <%= @letter.address.state %></div>
          </div>
          <div>
            <div style="color: var(--fgColor-muted); font-size: 12px;">Dimensions</div>
            <div><%= @letter.height %>" x <%= @letter.width %>"</div>
          </div>
          <div>
            <div style="color: var(--fgColor-muted); font-size: 12px;">Weight</div>
            <div><%= @letter.weight %> oz</div>
          </div>
        </div>
      <% end
    end %>
    <% if @letter.non_machinable? %>
      <%= render Primer::Beta::Flash.new(scheme: :warning, mt: 3) do %>
        Non-machinable surcharge applies
      <% end %>
    <% end %>
  </div>

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Purchase Postage</h2>
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_body do %>
        <%= form_with(url: buy_indicia_letter_path(@letter), method: :post) do |form| %>
          <div style="margin-bottom: 12px;">
            <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px;">USPS Payment Account</label>
            <%= form.collection_select :usps_payment_account_id,
              USPS::PaymentAccount.all,
              :id,
              :name,
              { prompt: "Select account...", selected: USPS::PaymentAccount.first&.id },
              { required: true, style: "width: 100%; padding: 5px 12px; border: 1px solid var(--borderColor-default); border-radius: 6px; font-size: 14px; background: var(--bgColor-default); color: var(--fgColor-default);" } %>
          </div>

          <% if current_user.hcb_payment_accounts.any? %>
            <div style="margin-bottom: 16px;">
              <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px;">Pay with HCB Organization</label>
              <%= form.collection_select :hcb_payment_account_id,
                current_user.hcb_payment_accounts,
                :id,
                :organization_name,
                { prompt: "Select organization..." },
                { required: true, style: "width: 100%; padding: 5px 12px; border: 1px solid var(--borderColor-default); border-radius: 6px; font-size: 14px; background: var(--bgColor-default); color: var(--fgColor-default);" } %>
            </div>
          <% else %>
            <%= render Primer::Beta::Flash.new(scheme: :default, mb: 3) do %>
              <%= link_to "Connect your HCB account", new_hcb_oauth_connection_path, style: "color: var(--fgColor-accent);" %> to pay for postage.
            <% end %>
          <% end %>

          <div style="display: flex; gap: 8px;">
            <%= render Primer::Beta::Button.new(tag: :a, href: letter_path(@letter), scheme: :secondary) do
              "Cancel"
            end %>
            <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary, disabled: current_user.hcb_payment_accounts.empty?) do |btn|
              btn.with_leading_visual_icon(icon: :credit_card)
              "Buy Indicia"
            end %>
          </div>
        <% end %>
      <% end
    end %>
  </div>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to letter", letter_path(@letter), style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
