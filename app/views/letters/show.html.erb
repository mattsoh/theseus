<% content_for :title, "#{@letter.user_facing_title || 'Letter'} #{@letter.public_id}" %>

<div class="page-container">
  <div class="page-header">
    <div>
      <div class="page-title-group">
        <h1 class="page-title">
          <% if @letter.user_facing_title.present? %>
            <%= @letter.user_facing_title %>
          <% else %>
            Letter to <%= @letter.address.name_line %>
          <% end %>
        </h1>
        <% status_scheme = { pending: :secondary, printed: :accent, mailed: :success, received: :done, canceled: :attention, errored: :danger }[@letter.aasm_state.to_sym] || :secondary %>
        <%= render(Primer::Beta::Label.new(scheme: status_scheme, size: :large)) { @letter.aasm_state.humanize } %>
      </div>
      <p class="page-subtitle">
        <%= render Components::Shared::PublicId.new(value: @letter.public_id) %>
      </p>
    </div>

    <div class="page-actions">
      <%= render Primer::Beta::Button.new(tag: :a, href: edit_letter_path(@letter), scheme: :secondary, size: :medium) do |btn|
        btn.with_leading_visual_icon(icon: :pencil)
        "Edit"
      end %>
      <%= render Primer::Beta::Button.new(tag: :a, href: public_letter_path(@letter), scheme: :secondary, size: :medium, target: "_blank") do |btn|
        btn.with_leading_visual_icon(icon: :"link-external")
        "Public Page"
      end %>
      <%= form_with url: letter_path(@letter), method: :delete, data: { turbo_confirm: "Delete this letter?" }, class: "form-inline" do %>
        <%= render Primer::Beta::Button.new(type: :submit, scheme: :danger, size: :medium) do |btn|
          btn.with_leading_visual_icon(icon: :trash)
          "Delete"
        end %>
      <% end %>
    </div>
  </div>

  <% if @letter.tags.present? %>
    <div class="tags-row">
      <% @letter.tags.compact_blank.each do |tag| %>
        <%= render(Primer::Beta::Label.new(tag: :a, href: tag_stats_path(tag), scheme: :secondary)) { tag } %>
      <% end %>
    </div>
  <% end %>

  <div class="letter-layout">
    <div>
      <div class="content-section">
        <h2 class="section-heading">Addresses</h2>
        <div class="two-col-equal">
          <%= render Primer::Beta::BorderBox.new do |box|
            box.with_header { "From" }
            box.with_row do %>
              <% if @letter.return_address.present? %>
                <div class="address-block">
                  <div class="fw-semibold"><%= @letter.return_address_name_line %></div>
                  <div class="kv-label">
                    <%= @letter.return_address.line_1 %><br>
                    <% if @letter.return_address.line_2.present? %><%= @letter.return_address.line_2 %><br><% end %>
                    <%= @letter.return_address.city %>, <%= @letter.return_address.state %> <%= @letter.return_address.postal_code %><br>
                    <%= @letter.return_address.country %>
                  </div>
                </div>
              <% else %>
                <span class="kv-label">No return address</span>
              <% end %>
            <% end
          end %>

          <%= render Primer::Beta::BorderBox.new do |box|
            box.with_header { "To" }
            box.with_row do %>
              <div class="address-block">
                <div class="fw-semibold"><%= @letter.address.name_line %></div>
                <div class="kv-label">
                  <%= @letter.address.line_1 %><br>
                  <% if @letter.address.line_2.present? %><%= @letter.address.line_2 %><br><% end %>
                  <%= @letter.address.city %>, <%= @letter.address.state %> <%= @letter.address.postal_code %><br>
                  <%= @letter.address.country %>
                </div>
              </div>
            <% end
          end %>
        </div>
      </div>

      <div class="content-section">
        <h2 class="section-heading">Specifications</h2>
        <%= render 'shared/letter_attributes', record: @letter %>
      </div>

      <div class="content-section">
        <h2 class="section-heading">Postage</h2>
        <%= render Primer::Beta::BorderBox.new do |box|
          if @letter.postage_type == "indicia"
            if @letter.usps_indicium.present?
              box.with_row do %>
                <div class="page-title-group">
                  <%= render Primer::Beta::Octicon.new(icon: :check_circle, color: :success) %>
                  <span class="fw-semibold text-success">Indicia Purchased</span>
                </div>
              <% end
              box.with_row do %>
                <div class="detail-grid">
                  <div>
                    <div class="detail-label">Cost</div>
                    <div class="fw-medium"><%= number_to_currency(@letter.usps_indicium.cost) %>
                      <span class="kv-label">(<%= number_to_currency(@letter.usps_indicium.postage) %> + <%= number_to_currency(@letter.usps_indicium.fees || 0) %> fees)</span>
                    </div>
                  </div>
                  <div>
                    <div class="detail-label">Mailing Date</div>
                    <div><%= @letter.usps_indicium.mailing_date %></div>
                  </div>
                  <div>
                    <div class="detail-label">USPS SKU</div>
                    <code><%= @letter.usps_indicium.usps_sku %></code>
                  </div>
                  <div>
                    <div class="detail-label">Indicium ID</div>
                    <%= render Components::Shared::PublicId.new(value: @letter.usps_indicium.public_id) %>
                  </div>
                </div>
              <% end
              admin_tool do %>
                <% if @letter.usps_indicium.raw_json_response.nil? %>
                  <div class="py-2">
                    <%= form_with url: clear_indicium_letter_path(@letter), method: :post, data: { turbo_confirm: "This will destroy the orphaned indicium. Are you sure?" }, class: "form-inline" do %>
                      <%= render Primer::Beta::Button.new(type: :submit, scheme: :danger, size: :small) do |btn|
                        btn.with_leading_visual_icon(icon: :trash)
                        "Clear Orphaned Indicium"
                      end %>
                    <% end %>
                  </div>
                <% end %>
              <% end %>
              <%= render 'admin_inspector', record: @letter.usps_indicium %>
            <% else
              box.with_row do %>
                <div class="page-title-group">
                  <%= render Primer::Beta::Octicon.new(icon: :alert, color: :attention) %>
                  <span class="fw-medium text-attention">Indicia Not Purchased</span>
                </div>
              <% end
              box.with_row do %>
                <% if @letter.batch_id.nil? %>
                  <%= render 'buy_indicia_form', letter: @letter %>
                <% else %>
                  <span class="kv-label">Postage will be purchased when processing the batch.</span>
                <% end %>
              <% end
            end
          elsif @letter.postage_type == "international_origin"
            box.with_row do %>
              <div>
                <%= render(Primer::Beta::Label.new(scheme: :accent)) { "International Origin" } %>
                <span class="kv-label">Postage paid at origin (<%= @letter.return_address&.country %>)</span>
              </div>
            <% end
          else
            box.with_row do %>
              <div class="kv-row">
                <span class="kv-label">Using physical stamps</span>
                <% if @letter.batch_id.nil? %>
                  <%= form_with url: letter_path(@letter), method: :patch, class: "form-inline" do |f| %>
                    <%= f.hidden_field :postage_type, value: "indicia", name: "letter[postage_type]" %>
                    <%= render Primer::Beta::Button.new(type: :submit, scheme: :secondary, size: :small) { "Switch to Indicia" } %>
                  <% end %>
                <% end %>
              </div>
            <% end
          end
        end %>
      </div>

      <% if @letter.batch.present? %>
        <%= render 'shared/batch_info', record: @letter %>
      <% end %>

      <% if @letter.imb_serial_number.present? && @letter.address.country&.upcase == 'US' %>
        <div class="content-section">
          <h2 class="section-heading">IMb Tracking</h2>
          <%= render Primer::Beta::BorderBox.new do |box|
            box.with_row do %>
              <div class="detail-grid">
                <div>
                  <div class="detail-label">Serial</div>
                  <code><%= @letter.imb_serial_number.to_s.rjust(6, '0') %></code>
                </div>
                <div>
                  <div class="detail-label">Epoch</div>
                  <span><%= @letter.imb_rollover_count %></span>
                </div>
              </div>
            <% end
          end %>
        </div>
      <% end %>

      <% if @letter.rubber_stamps.present? %>
        <div class="content-section">
          <h2 class="section-heading">Rubber Stamps</h2>
          <%= render Primer::Beta::BorderBox.new do |box|
            box.with_row do %>
              <pre class="pre-wrap"><%= @letter.rubber_stamps %></pre>
            <% end
          end %>
        </div>
      <% end %>

      <%= render partial: "admin_inspector", locals: { record: @letter } %>
    </div>

    <div>
      <div class="sticky-sidebar">
        <h2 class="section-heading">Actions</h2>
        <%= render Primer::Beta::BorderBox.new(mb: 4) do |box|
          box.with_body do %>
            <% case @letter.aasm_state %>
            <% when 'pending' %>
              <% if @letter.label.attached? %>
                <div class="form-field">
                  <div class="detail-label">Label Ready</div>
                  <div class="page-actions">
                    <%= render Primer::Beta::Button.new(tag: :a, href: rails_blob_path(@letter.label, disposition: 'inline'), scheme: :secondary, size: :small, target: "_blank") do |btn|
                      btn.with_leading_visual_icon(icon: :eye)
                      "View Label"
                    end %>
                    <%= form_with url: clear_label_letter_path(@letter), method: :post, data: { turbo_confirm: "Clear this label?" }, class: "form-inline" do %>
                      <%= render Primer::Beta::Button.new(type: :submit, scheme: :secondary, size: :small) do |btn|
                        btn.with_leading_visual_icon(icon: :x)
                        "Clear"
                      end %>
                    <% end %>
                  </div>
                </div>
                <hr class="divider">
                <%= form_with url: mark_printed_letter_path(@letter), method: :post do %>
                  <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary, block: true) do |btn|
                    btn.with_leading_visual_icon(icon: :check)
                    "Mark as Printed"
                  end %>
                <% end %>
              <% elsif @letter.batch.present? %>
                <%= form_with url: mark_printed_letter_path(@letter), method: :post do %>
                  <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary, block: true) do |btn|
                    btn.with_leading_visual_icon(icon: :check)
                    "Mark as Printed"
                  end %>
                <% end %>
              <% else %>
                <div class="detail-label">Generate Label</div>
                <%= form_tag(generate_label_letter_path(@letter), method: :post) do %>
                  <div class="form-field">
                    <%= render 'shared/template_picker', multiple: false %>
                    <input type="hidden" name="template" id="selected_template">
                  </div>
                  <div class="form-field">
                    <%= render Primer::Alpha::CheckBox.new(
                      name: "qr",
                      label: "Include QR Code",
                      value: "1",
                      checked: true
                    ) %>
                  </div>
                  <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary, block: true) do |btn|
                    btn.with_leading_visual_icon(icon: :file)
                    "Generate Label"
                  end %>
                <% end %>
                <% dev_tool do %>
                  <div class="mt-2">
                    <%= link_to "preview label?", preview_template_letter_path(@letter), class: "resource-card-meta" %>
                  </div>
                <% end %>
              <% end %>
            <% when 'printed' %>
              <%= form_with url: mark_mailed_letter_path(@letter), method: :post do %>
                <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary, block: true) do |btn|
                  btn.with_leading_visual_icon(icon: :check)
                  "Mark as Mailed"
                end %>
              <% end %>
            <% when 'mailed' %>
              <%= form_with url: mark_received_letter_path(@letter), method: :post do %>
                <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary, block: true) do |btn|
                  btn.with_leading_visual_icon(icon: :check)
                  "Mark as Received"
                end %>
              <% end %>
            <% when 'received' %>
              <div class="letter-received-card">
                <%= render Primer::Beta::Octicon.new(icon: :check_circle, size: :medium) %>
                <div class="fw-semibold mt-1">Letter received</div>
              </div>
            <% end %>
          <% end
        end %>

        <% if @letter.label.attached? %>
          <%= render 'shared/instant_print_window', url: rails_blob_path(@letter.label, disposition: 'inline') %>
          <h2 class="section-heading">Label Preview</h2>
          <%= render Primer::Beta::BorderBox.new do |box|
            box.with_body do %>
              <div class="label-preview">
                <iframe src="<%= rails_blob_path(@letter.label, disposition: 'inline') %>"></iframe>
              </div>
              <div class="mt-3">
                <%= link_to "Download Label", rails_blob_path(@letter.label, disposition: "attachment"), class: "resource-card-meta" %>
              </div>
            <% end
          end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="back-link">
    <%= render Primer::Beta::Button.new(tag: :a, href: letters_path, scheme: :invisible, size: :small) do |btn|
      btn.with_leading_visual_icon(icon: :"arrow-left")
      "Back to letters"
    end %>
  </div>
</div>
