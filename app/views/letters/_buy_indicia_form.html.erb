<%= form_with(url: buy_indicia_letter_path(letter), method: :post) do |form| %>
  <% if current_user.hcb_payment_accounts.any? %>
    <div style="margin-bottom: 12px;">
      <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px;">Pay with HCB Organization</label>
      <%= form.collection_select :hcb_payment_account_id,
        current_user.hcb_payment_accounts,
        :id,
        :organization_name,
        { prompt: "Select organization..." },
        { required: true, style: "width: 100%; padding: 5px 12px; border: 1px solid var(--borderColor-default); border-radius: 6px; font-size: 14px; background: var(--bgColor-default); color: var(--fgColor-default);" } %>
    </div>

    <div style="margin-bottom: 12px;">
      <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px;">USPS Payment Account</label>
      <%= form.collection_select :usps_payment_account_id,
        USPS::PaymentAccount.all,
        :id,
        :name,
        { selected: USPS::PaymentAccount.first&.id },
        { required: true, style: "width: 100%; padding: 5px 12px; border: 1px solid var(--borderColor-default); border-radius: 6px; font-size: 14px; background: var(--bgColor-default); color: var(--fgColor-default);" } %>
    </div>

    <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary, block: true) do |btn|
      btn.with_leading_visual_icon(icon: :credit_card)
      "Buy Indicia"
    end %>
  <% else %>
    <div style="text-align: center; padding: 16px;">
      <p style="font-size: 14px; color: var(--fgColor-muted); margin-bottom: 12px;">Connect your HCB account to purchase postage.</p>
      <%= render Primer::Beta::Button.new(tag: :a, href: new_hcb_oauth_connection_path, scheme: :secondary, size: :small) do
        "Connect HCB"
      end %>
    </div>
  <% end %>
<% end %>
