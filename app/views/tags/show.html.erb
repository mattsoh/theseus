<% content_for :title, "Tag: #{@tag}" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="margin-bottom: 24px;">
    <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 8px 0;">
      <%= render(Primer::Beta::Label.new(scheme: :accent, size: :large)) { @tag } %>
    </h1>
  </div>

  <div style="margin-bottom: 24px;">
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_body do %>
        <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
          <span style="color: var(--fgColor-muted); font-size: 14px;">Showing:</span>
          <%= render Primer::Alpha::Select.new(name: "time_period", label: "Time period", visually_hide_label: true, id: "time_period") do |select|
            select.with_option(value: "all_time", label: "All-time", selected: @time_period == "all_time")
            select.with_option(value: "ytd", label: "Year-to-date", selected: @time_period == "ytd")
            select.with_option(value: "month", label: "Specific month", selected: @time_period == "month")
            select.with_option(value: "last_week", label: "Last week", selected: @time_period == "last_week")
            select.with_option(value: "last_month", label: "Last month", selected: @time_period == "last_month")
            select.with_option(value: "last_year", label: "Last year", selected: @time_period == "last_year")
          end %>

          <span id="year_selector" style="display: <%= @time_period.in?(%w[ytd month]) ? 'inline' : 'none' %>">
            <%= render Primer::Alpha::Select.new(name: "year", label: "Year", visually_hide_label: true, id: "year") do |select|
              @years.each do |y|
                select.with_option(value: y.to_s, label: y.to_s, selected: y == @year)
              end
            end %>
          </span>

          <span id="month_selector" style="display: <%= @time_period == 'month' ? 'inline' : 'none' %>">
            <%= render Primer::Alpha::Select.new(name: "month", label: "Month", visually_hide_label: true, id: "month") do |select|
              @months.each do |name, num|
                select.with_option(value: num.to_s, label: name, selected: num == @month)
              end
            end %>
          </span>

          <%= render Primer::Beta::Button.new(scheme: :secondary, size: :small, tag: :button, "onclick": "updateTimePeriod()") { "Go" } %>
        </div>
      <% end
    end %>
  </div>

  <div style="display: flex; gap: 12px; margin-bottom: 24px; flex-wrap: wrap;">
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_body do %>
        <div style="text-align: center; min-width: 80px;">
          <div style="font-size: 24px; font-weight: 600; line-height: 1;"><%= @warehouse_order_count %></div>
          <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px;">Warehouse Orders</div>
        </div>
      <% end
    end %>
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_body do %>
        <div style="text-align: center; min-width: 80px;">
          <div style="font-size: 24px; font-weight: 600; line-height: 1;"><%= @letter_count %></div>
          <div style="font-size: 12px; color: var(--fgColor-muted); margin-top: 4px;">Letters</div>
        </div>
      <% end
    end %>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
    <div>
      <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Letter Costs</h2>
      <%= render Primer::Beta::BorderBox.new do |box|
        box.with_row do %>
          <div class="kv-row"><span class="kv-label">Postage</span><span style="font-weight: 600;"><%= number_to_currency(@letter_postage_cost) %></span></div>
        <% end
      end %>
    </div>

    <div>
      <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Warehouse Costs</h2>
      <%= render Primer::Beta::BorderBox.new do |box|
        box.with_row do %>
          <div class="kv-row"><span class="kv-label">Postage</span><span><%= number_to_currency(@warehouse_order_postage_cost) %></span></div>
        <% end
        box.with_row do %>
          <div class="kv-row"><span class="kv-label">Labor</span><span><%= number_to_currency(@warehouse_order_labor_cost) %></span></div>
        <% end
        box.with_row do %>
          <div class="kv-row"><span class="kv-label">Contents</span><span><%= number_to_currency(@warehouse_order_contents_cost) %></span></div>
        <% end
        box.with_footer do %>
          <div class="kv-row" style="font-weight: 600;"><span>Total</span><span><%= number_to_currency(@warehouse_order_total_cost) %></span></div>
        <% end
      end %>
    </div>
  </div>

  <div style="margin-top: 32px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: tags_path, scheme: :invisible, size: :small) do |btn|
      btn.with_leading_visual_icon(icon: :"arrow-left")
      "Back to tags"
    end %>
  </div>
</div>

<style>
  .kv-row { display: flex; justify-content: space-between; align-items: center; }
  .kv-label { color: var(--fgColor-muted); }
</style>

<script>
  function updateTimePeriod() {
    const timePeriod = document.getElementById('time_period').value;
    const year = document.getElementById('year').value;
    const month = document.getElementById('month').value;

    document.getElementById('year_selector').style.display =
      timePeriod === 'ytd' || timePeriod === 'month' ? 'inline' : 'none';
    document.getElementById('month_selector').style.display =
      timePeriod === 'month' ? 'inline' : 'none';

    let url = '<%= tag_stats_path(@tag) %>?time_period=' + timePeriod;
    if (timePeriod === 'ytd' || timePeriod === 'month') url += '&year=' + year;
    if (timePeriod === 'month') url += '&month=' + month;

    window.location.href = url;
  }

  document.getElementById('time_period').addEventListener('change', function() {
    const timePeriod = this.value;
    document.getElementById('year_selector').style.display =
      timePeriod === 'ytd' || timePeriod === 'month' ? 'inline' : 'none';
    document.getElementById('month_selector').style.display =
      timePeriod === 'month' ? 'inline' : 'none';
  });
</script>
