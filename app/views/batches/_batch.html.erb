<div id="<%= dom_id batch %>" style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start;">
  <div>
    <%= render Primer::Beta::BorderBox.new do |box| %>
      <% box.with_header do %>
        <div style="display: flex; align-items: center; gap: 8px;">
          <span style="font-weight: 600;"><%= batch.type.split('::').first.titleize %> Batch #<%= batch.id %></span>
          <%= render Components::Shared::StatusBadge.new(status: batch.aasm.current_state, type: :batch) %>
        </div>
      <% end %>
      <% box.with_body do %>
        <% if batch.tags.any? %>
          <div style="margin-bottom: 12px;">
            <%= render 'shared/tags', tags: batch.tags %>
          </div>
        <% end %>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
          <%# Batch Information %>
          <div>
            <h3 style="font-size: 14px; font-weight: 600; margin: 0 0 8px 0;">Batch Information</h3>
            <%= render Primer::Beta::BorderBox.new do |info_box| %>
              <% info_box.with_row do %>
                <span style="color: var(--fgColor-muted);">Created</span>
                <span style="float: right;"><%= batch.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
              <% end %>
              <% if batch.csv.attached? %>
                <% info_box.with_row do %>
                  <span style="color: var(--fgColor-muted);">CSV File</span>
                  <span style="float: right;"><%= batch.csv.filename %></span>
                <% end %>
              <% end %>
              <% info_box.with_row do %>
                <span style="color: var(--fgColor-muted);">Address Count</span>
                <span style="float: right;"><%= batch.addresses.count %></span>
              <% end %>
              <% if batch.is_a?(Letter::Batch) %>
                <% info_box.with_row do %>
                  <span style="color: var(--fgColor-muted);">Dimensions</span>
                  <span style="float: right;"><%= batch.letter_width %>" × <%= batch.letter_height %>"</span>
                <% end %>
                <% info_box.with_row do %>
                  <span style="color: var(--fgColor-muted);">Weight</span>
                  <span style="float: right;"><%= batch.letter_weight %> oz</span>
                <% end %>
              <% end %>
              <% if batch.is_a?(Warehouse::Batch) && batch.warehouse_template.present? %>
                <% info_box.with_row do %>
                  <span style="color: var(--fgColor-muted);">Template</span>
                  <span style="float: right;"><%= batch.warehouse_template.name %></span>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <%# Cost Information %>
          <div>
            <h3 style="font-size: 14px; font-weight: 600; margin: 0 0 8px 0;">Cost Information</h3>
            <%= render Primer::Beta::BorderBox.new do |cost_box| %>
              <% if batch.is_a?(Warehouse::Batch) %>
                <% cost_box.with_row do %>
                  <span style="color: var(--fgColor-muted);">Contents</span>
                  <span style="float: right; font-family: var(--fontStack-monospace);"><%= number_to_currency(batch.contents_cost) %></span>
                <% end %>
                <% cost_box.with_row do %>
                  <span style="color: var(--fgColor-muted);">Labor</span>
                  <span style="float: right; font-family: var(--fontStack-monospace);"><%= number_to_currency(batch.labor_cost) %></span>
                <% end %>
                <% cost_box.with_row do %>
                  <span style="color: var(--fgColor-muted);">Shipping</span>
                  <span style="float: right; font-family: var(--fontStack-monospace);"><%= number_to_currency(batch.postage_cost) %></span>
                <% end %>
              <% end %>
              <% cost_box.with_row do %>
                <span style="font-weight: 600;">Total Cost</span>
                <span style="float: right; font-weight: 600; font-family: var(--fontStack-monospace);"><%= number_to_currency(batch.total_cost) %></span>
              <% end %>
            <% end %>
          </div>
        </div>

        <% if batch.is_a?(Letter::Batch) && batch.labels_pdf.attached? %>
          <div style="margin-top: 16px;">
            <h3 style="font-size: 14px; font-weight: 600; margin: 0 0 8px 0;">Letter Labels</h3>
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 12px; border: 1px solid var(--borderColor-default); border-radius: 6px; background: var(--bgColor-muted);">
              <span style="font-size: 14px;">PDF labels are available for this batch.</span>
              <%= render Primer::Beta::Button.new(tag: :a, href: rails_blob_path(batch.labels_pdf, disposition: "attachment"), target: "_blank", scheme: :primary, size: :small) do |btn|
                btn.with_leading_visual_icon(icon: :download)
                "Download PDF"
              end %>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <%# Sidebar: Actions %>
  <div style="position: sticky; top: 24px;">
    <%= render Primer::Beta::BorderBox.new do |box| %>
      <% box.with_header do %>
        <span style="font-weight: 600;">Actions</span>
      <% end %>
      <% box.with_body do %>
        <% case batch.aasm_state %>
        <% when "awaiting_field_mapping" %>
          <% map_path = batch.is_a?(Letter::Batch) ? map_fields_letter_batch_path(batch) : map_fields_warehouse_batch_path(batch) %>
          <%= render Primer::Beta::Button.new(tag: :a, href: map_path, scheme: :primary, block: true) do |btn|
            btn.with_leading_visual_icon(icon: :list_unordered)
            "Map Fields"
          end %>
        <% when "fields_mapped" %>
          <% process_path = batch.is_a?(Letter::Batch) ? process_confirm_letter_batch_path(batch) : process_confirm_warehouse_batch_path(batch) %>
          <%= render Primer::Beta::Button.new(tag: :a, href: process_path, scheme: :primary, block: true) do |btn|
            btn.with_leading_visual_icon(icon: :play)
            "Process Batch"
          end %>
        <% when "processed" %>
          <p style="color: var(--fgColor-muted); font-size: 14px; margin: 0;">This batch has been processed.</p>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
