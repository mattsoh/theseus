<div id="<%= dom_id batch %>" class="batch-layout">
  <div>
    <%= render Primer::Beta::BorderBox.new do |box| %>
      <% box.with_header do %>
        <div class="kv-row">
          <span class="col-header"><%= batch.type.split('::').first.titleize %> Batch #<%= batch.id %></span>
          <%= render Components::Shared::StatusBadge.new(status: batch.aasm.current_state, type: :batch) %>
        </div>
      <% end %>
      <% box.with_body do %>
        <% if batch.tags.any? %>
          <div class="mb-2">
            <%= render 'shared/tags', tags: batch.tags %>
          </div>
        <% end %>

        <div class="two-col-equal">
          <div>
            <h3 class="section-heading">Batch Information</h3>
            <%= render Primer::Beta::BorderBox.new do |info_box| %>
              <% info_box.with_row do %>
                <div class="kv-row"><span class="kv-label">Created</span><span><%= batch.created_at.strftime("%B %d, %Y at %I:%M %p") %></span></div>
              <% end %>
              <% if batch.csv.attached? %>
                <% info_box.with_row do %>
                  <div class="kv-row"><span class="kv-label">CSV File</span><span><%= batch.csv.filename %></span></div>
                <% end %>
              <% end %>
              <% info_box.with_row do %>
                <div class="kv-row"><span class="kv-label">Address Count</span><span><%= batch.addresses.count %></span></div>
              <% end %>
              <% if batch.is_a?(Letter::Batch) %>
                <% info_box.with_row do %>
                  <div class="kv-row"><span class="kv-label">Dimensions</span><span><%= batch.letter_width %>" × <%= batch.letter_height %>"</span></div>
                <% end %>
                <% info_box.with_row do %>
                  <div class="kv-row"><span class="kv-label">Weight</span><span><%= batch.letter_weight %> oz</span></div>
                <% end %>
              <% end %>
              <% if batch.is_a?(Warehouse::Batch) && batch.warehouse_template.present? %>
                <% info_box.with_row do %>
                  <div class="kv-row"><span class="kv-label">Template</span><span><%= batch.warehouse_template.name %></span></div>
                <% end %>
              <% end %>
            <% end %>
          </div>

          <div>
            <h3 class="section-heading">Cost Information</h3>
            <%= render Primer::Beta::BorderBox.new do |cost_box| %>
              <% if batch.is_a?(Warehouse::Batch) %>
                <% cost_box.with_row do %>
                  <div class="kv-row"><span class="kv-label">Contents</span><span class="mono"><%= number_to_currency(batch.contents_cost) %></span></div>
                <% end %>
                <% cost_box.with_row do %>
                  <div class="kv-row"><span class="kv-label">Labor</span><span class="mono"><%= number_to_currency(batch.labor_cost) %></span></div>
                <% end %>
                <% cost_box.with_row do %>
                  <div class="kv-row"><span class="kv-label">Shipping</span><span class="mono"><%= number_to_currency(batch.postage_cost) %></span></div>
                <% end %>
              <% end %>
              <% cost_box.with_row do %>
                <div class="kv-row"><span class="fw-semibold">Total Cost</span><span class="mono fw-semibold"><%= number_to_currency(batch.total_cost) %></span></div>
              <% end %>
            <% end %>
          </div>
        </div>

        <% if batch.is_a?(Letter::Batch) && batch.labels_pdf.attached? %>
          <div class="mt-3">
            <h3 class="section-heading">Letter Labels</h3>
            <div class="info-card">
              <div class="kv-row">
                <span>PDF labels are available for this batch.</span>
                <%= render Primer::Beta::Button.new(tag: :a, href: rails_blob_path(batch.labels_pdf, disposition: "attachment"), target: "_blank", scheme: :primary, size: :small) do |btn|
                  btn.with_leading_visual_icon(icon: :download)
                  "Download PDF"
                end %>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <div class="sticky-sidebar">
    <%= render Primer::Beta::BorderBox.new do |box| %>
      <% box.with_header do %>
        <span class="col-header">Actions</span>
      <% end %>
      <% box.with_body do %>
        <% case batch.aasm_state %>
        <% when "awaiting_field_mapping" %>
          <% map_path = batch.is_a?(Letter::Batch) ? map_fields_letter_batch_path(batch) : map_fields_warehouse_batch_path(batch) %>
          <%= render Primer::Beta::Button.new(tag: :a, href: map_path, scheme: :primary, block: true) do |btn|
            btn.with_leading_visual_icon(icon: :list_unordered)
            "Map Fields"
          end %>
        <% when "fields_mapped" %>
          <% process_path = batch.is_a?(Letter::Batch) ? process_confirm_letter_batch_path(batch) : process_confirm_warehouse_batch_path(batch) %>
          <%= render Primer::Beta::Button.new(tag: :a, href: process_path, scheme: :primary, block: true) do |btn|
            btn.with_leading_visual_icon(icon: :play)
            "Process Batch"
          end %>
        <% when "processed" %>
          <p class="kv-label mb-0">This batch has been processed.</p>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
