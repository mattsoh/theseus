<%= render Primer::Beta::BorderBox.new do |box| %>
  <% box.with_header do %>
    <div class="batch-table-row">
      <span class="batch-col-name" style="font-weight: 600;">Letter</span>
      <span class="batch-col-md" style="font-weight: 600;">From</span>
      <span class="batch-col-md" style="font-weight: 600;">Size</span>
      <span class="batch-col-md" style="font-weight: 600;">Created</span>
      <span class="batch-col-status" style="font-weight: 600;">Status</span>
    </div>
  <% end %>
  <% letters.each do |letter| %>
    <% box.with_row do %>
      <div class="batch-table-row">
        <div class="batch-col-name">
          <%= link_to letter.public_id, letter, style: "font-weight: 500;" %>
          <span class="kv-label" style="font-size: 13px;"> to <%= letter.address.name_line %></span>
        </div>
        <span class="batch-col-md kv-label" style="font-size: 13px;"><%= letter.return_address.present? ? letter.return_address_name_line : '—' %></span>
        <span class="batch-col-md" style="font-size: 13px;"><%= letter.height %>" × <%= letter.width %>"</span>
        <span class="batch-col-md kv-label" style="font-size: 13px;"><%= time_ago_in_words(letter.created_at) %> ago</span>
        <span class="batch-col-status">
          <%= render Components::Shared::StatusBadge.new(status: letter.aasm_state, type: :letter) %>
        </span>
      </div>
    <% end %>
  <% end %>
<% end %>
