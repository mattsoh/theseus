<%= render Primer::Beta::BorderBox.new do |box| %>
  <% box.with_header do %>
    <div class="batch-table-row">
      <span class="batch-col-name col-header">Letter</span>
      <span class="batch-col-md col-header">From</span>
      <span class="batch-col-md col-header">Size</span>
      <span class="batch-col-md col-header">Created</span>
      <span class="batch-col-status col-header">Status</span>
    </div>
  <% end %>
  <% letters.each do |letter| %>
    <% box.with_row do %>
      <div class="batch-table-row">
        <div class="batch-col-name">
          <%= link_to letter.public_id, letter, class: "fw-medium" %>
          <span class="kv-label text-sm"> to <%= letter.address.name_line %></span>
        </div>
        <span class="batch-col-md kv-label text-sm"><%= letter.return_address.present? ? letter.return_address_name_line : '—' %></span>
        <span class="batch-col-md text-sm"><%= letter.height %>" × <%= letter.width %>"</span>
        <span class="batch-col-md kv-label text-sm"><%= time_ago_in_words(letter.created_at) %> ago</span>
        <span class="batch-col-status">
          <%= render Components::Shared::StatusBadge.new(status: letter.aasm_state, type: :letter) %>
        </span>
      </div>
    <% end %>
  <% end %>
<% end %>
