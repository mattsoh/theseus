<%= render Primer::Beta::BorderBox.new do |box| %>
  <% orders.each do |order| %>
    <% box.with_row do %>
      <div style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
        <div style="flex: 1; min-width: 0;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
            <%= link_to order.hc_id, order, style: "color: var(--fgColor-accent); font-weight: 500; font-family: var(--fontStack-monospace);" %>
            <span style="font-size: 14px;"><%= order.user_facing_title %></span>
            <%= render 'warehouse/orders/status_badge', order: order %>
          </div>
          <div style="font-size: 13px; color: var(--fgColor-muted);">
            <%= order.address.name_line %> (<%= order.recipient_email %>)
          </div>
          <% if order.tags.any? %>
            <div style="margin-top: 4px;">
              <%= render 'shared/tags', tags: order.tags %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
