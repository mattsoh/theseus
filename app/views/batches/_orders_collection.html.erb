<%= render Primer::Beta::BorderBox.new do |box| %>
  <% orders.each do |order| %>
    <% box.with_row do %>
      <div class="resource-card">
        <div class="resource-card-info flex-1">
          <div class="order-collection-header">
            <%= link_to order.hc_id, order, class: "mono fw-medium" %>
            <span><%= order.user_facing_title %></span>
            <%= render 'warehouse/orders/status_badge', order: order %>
          </div>
          <span class="resource-card-meta"><%= order.address.name_line %> (<%= order.recipient_email %>)</span>
          <% if order.tags.any? %>
            <div class="mt-1">
              <%= render 'shared/tags', tags: order.tags %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  <% end %>
<% end %>
