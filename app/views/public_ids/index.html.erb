<div style="max-width: 600px; margin: 0 auto; padding: 24px;">
  <h1 style="font-size: 24px; font-weight: 600; margin: 0 0 16px;">ID Lookup</h1>
  <p style="color: var(--fgColor-muted); margin-bottom: 24px;">Enter a Theseus ID or tracking number to look it up.</p>
  <%= form_with url: lookup_public_ids_path, method: :post do |f| %>
    <div style="display: flex; gap: 8px; align-items: flex-end;">
      <%= render Primer::Alpha::TextField.new(
        name: :id,
        label: "ID",
        placeholder: "e.g. ltr!abc123, 9400111...",
        full_width: true,
        autofocus: true
      ) %>
      <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary) do |btn|
        btn.with_leading_visual_icon(icon: :search)
        "Look up"
      end %>
    </div>
  <% end %>
</div>
