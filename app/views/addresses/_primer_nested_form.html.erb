<%
  def country_flag(code)
    return "" if code.blank?
    code.upcase.chars.map { |c| (c.ord + 127397).chr(Encoding::UTF_8) }.join
  end

  countries_with_flags = Address.countries_for_select.map do |code, name|
    { 
      code: code, 
      name: name, 
      flag: country_flag(code), 
      display: "#{country_flag(code)}  #{name}",
      filter: "#{code}#{code}#{code} #{name}"
    }
  end

  top_codes = %w[US CA]
  top_countries = top_codes.map { |code| countries_with_flags.find { |c| c[:code] == code } }.compact
  other_countries = countries_with_flags.reject { |c| top_codes.include?(c[:code]) }
  all_ordered = top_countries + other_countries
%>

<%= form.fields_for :address do |a| %>
  <% form_id = "address-form-#{SecureRandom.hex(4)}" %>
  <% current_country = a.object&.country %>
  <% current_entry = countries_with_flags.find { |c| c[:code] == current_country } %>

  <div id="<%= form_id %>" style="display: grid; gap: 20px; max-width: 540px;">
    <%# Row 1: Name %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
      <%= render Primer::Alpha::TextField.new(
        name: "#{form.object_name}[address_attributes][first_name]",
        label: "First name",
        value: a.object&.first_name,
        required: true,
        full_width: true
      ) %>
      <%= render Primer::Alpha::TextField.new(
        name: "#{form.object_name}[address_attributes][last_name]",
        label: "Last name",
        value: a.object&.last_name,
        full_width: true
      ) %>
    </div>

    <%# Row 2: Street address %>
    <%= render Primer::Alpha::TextField.new(
      name: "#{form.object_name}[address_attributes][line_1]",
      label: "Street address",
      value: a.object&.line_1,
      required: true,
      full_width: true
    ) %>

    <%# Row 3: Apt/Suite %>
    <%= render Primer::Alpha::TextField.new(
      name: "#{form.object_name}[address_attributes][line_2]",
      label: "Apt, suite, unit, etc.",
      caption: "Optional",
      value: a.object&.line_2,
      full_width: true
    ) %>

    <%# Row 4: City / State / Postal %>
    <div style="display: grid; grid-template-columns: 1fr 80px 100px; gap: 16px;">
      <%= render Primer::Alpha::TextField.new(
        name: "#{form.object_name}[address_attributes][city]",
        label: "City",
        value: a.object&.city,
        required: true,
        full_width: true
      ) %>
      <%= render Primer::Alpha::TextField.new(
        name: "#{form.object_name}[address_attributes][state]",
        label: "State",
        value: a.object&.state,
        required: true,
        full_width: true
      ) %>
      <%= render Primer::Alpha::TextField.new(
        name: "#{form.object_name}[address_attributes][postal_code]",
        label: "Postal code",
        value: a.object&.postal_code,
        required: true,
        full_width: true
      ) %>
    </div>

    <%# Row 5: Country %>
    <div class="FormControl" style="max-width: 280px;">
      <label class="FormControl-label">
        Country <span class="color-fg-danger">*</span>
      </label>
      <div style="margin-top: 6px;">
        <%= render Primer::Alpha::SelectPanel.new(
          title: "Select country",
          size: :medium,
          fetch_strategy: :local,
          dynamic_label: true,
          select_variant: :single,
          form_arguments: { 
            builder: form, 
            name: "address_attributes[country]"
          }
        ) do |panel| %>
          <% panel.with_show_button(scheme: :secondary) do %>
            <span class="d-flex flex-items-center gap-2">
              <% if current_entry %>
                <span style="font-size: 1.2em; line-height: 1;"><%= current_entry[:flag] %></span>
                <span><%= current_entry[:name] %></span>
              <% else %>
                <span class="color-fg-muted">Select</span>
              <% end %>
            </span>
          <% end %>

          <% all_ordered.each do |country| %>
            <% panel.with_item(
              label: country[:display],
              content_arguments: { 
                data: { 
                  value: country[:code],
                  code: country[:code], 
                  name: country[:name] 
                }
              },
              data: { filter_string: country[:filter] },
              active: country[:code] == current_country
            ) %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var container = document.getElementById('<%= form_id %>');
      if (!container) return;
      
      function setupPanel() {
        var panel = container.querySelector('select-panel');
        if (!panel) return;
        
        // Custom filter: exact ISO code match beats substring match
        panel.filterFn = function(item, query) {
          var q = query.toLowerCase().trim();
          if (!q) return true;
          
          var itemContent = item.querySelector('[data-code]');
          var code = itemContent ? itemContent.dataset.code.toLowerCase() : '';
          var name = itemContent ? itemContent.dataset.name.toLowerCase() : '';
          
          if (code === q) return true;
          if (name.startsWith(q)) return true;
          
          return false;
        };
      }
      
      // Run after custom element is defined
      setupPanel();
      if (window.customElements) {
        window.customElements.whenDefined('select-panel').then(setupPanel);
      }
    })();
  </script>
<% end %>
