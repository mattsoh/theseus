<%= form_with(model: usps_mailer_id) do |form| %>
  <% if usps_mailer_id.errors.any? %>
    <%= render Primer::Beta::Flash.new(scheme: :danger, mb: 3) do %>
      <strong><%= pluralize(usps_mailer_id.errors.count, "error") %>:</strong>
      <ul style="margin: 8px 0 0 16px; padding: 0;">
        <% usps_mailer_id.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box| %>
    <% box.with_body do %>
      <%= render Primer::Alpha::TextField.new(
        name: "usps_mailer_id[name]",
        label: "Name",
        value: usps_mailer_id.name,
        full_width: true,
        mb: 3
      ) %>

      <%= render Primer::Alpha::TextField.new(
        name: "usps_mailer_id[crid]",
        label: "CRID",
        value: usps_mailer_id.crid,
        full_width: true,
        mb: 3
      ) %>

      <%= render Primer::Alpha::TextField.new(
        name: "usps_mailer_id[mid]",
        label: "MID",
        value: usps_mailer_id.mid,
        full_width: true
      ) %>
    <% end %>
  <% end %>

  <div style="display: flex; gap: 8px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: usps_mailer_ids_path, scheme: :secondary) do
      "Cancel"
    end %>
    <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :check)
      usps_mailer_id.persisted? ? "Update Mailer ID" : "Create Mailer ID"
    end %>
  </div>
<% end %>
