<% content_for :title, @usps_mailer_id.name %>

<div style="max-width: 800px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;">
    <h1 style="font-size: 24px; font-weight: 600; margin: 0;"><%= @usps_mailer_id.name %></h1>
    <div style="display: flex; gap: 8px;">
      <%= render Primer::Beta::Button.new(tag: :a, href: edit_usps_mailer_id_path(@usps_mailer_id), scheme: :secondary, size: :medium) do |btn|
        btn.with_leading_visual_icon(icon: :pencil)
        "Edit"
      end %>
      <%= form_with url: usps_mailer_id_path(@usps_mailer_id), method: :delete, data: { turbo_confirm: "Delete this mailer ID?" }, style: "display: inline;" do %>
        <%= render Primer::Beta::Button.new(type: :submit, scheme: :danger, size: :medium) do |btn|
          btn.with_leading_visual_icon(icon: :trash)
          "Delete"
        end %>
      <% end %>
    </div>
  </div>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box|
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Name</span><span><%= @usps_mailer_id.name %></span></div>
    <% end
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">CRID</span><code><%= @usps_mailer_id.crid %></code></div>
    <% end
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">MID</span><code><%= @usps_mailer_id.mid %></code></div>
    <% end
  end %>

  <%= render partial: "admin_inspector", locals: { record: @usps_mailer_id } %>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to mailer IDs", usps_mailer_ids_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
