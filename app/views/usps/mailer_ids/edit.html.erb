<% content_for :title, "Edit Mailer ID" %>

<div class="page-container--xs">
  <div class="page-title-group" style="margin-bottom: 24px;">
    <h1 class="page-title">Edit Mailer ID</h1>
    <span class="kv-label"><%= @usps_mailer_id.name %></span>
  </div>
  <%= render "form", usps_mailer_id: @usps_mailer_id %>
  <div style="margin-top: 32px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: usps_mailer_id_path(@usps_mailer_id), scheme: :invisible, size: :small) do |btn|
      btn.with_leading_visual_icon(icon: :"arrow-left")
      "Back to mailer ID"
    end %>
  </div>
</div>
