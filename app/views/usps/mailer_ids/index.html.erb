<% content_for :title, "Mailer IDs" %>

<div class="page-container">
  <div class="page-header">
    <div>
      <h1 class="page-title">CRID / Mailer ID Pairs</h1>
      <p class="page-subtitle"><%= @usps_mailer_ids.count %> registered</p>
    </div>
    <%= render Primer::Beta::Button.new(tag: :a, href: new_usps_mailer_id_path, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :plus)
      "New Mailer ID"
    end %>
  </div>

  <% if @usps_mailer_ids.any? %>
    <%= render Primer::Beta::BorderBox.new do |box|
      @usps_mailer_ids.each do |mid|
        box.with_row do %>
          <a href="<%= usps_mailer_id_path(mid) %>" class="resource-card" style="text-decoration: none; color: inherit;">
            <span class="resource-card-title"><%= mid.name %></span>
            <div class="resource-card-meta" style="display: flex; gap: 16px;">
              <span>CRID: <code><%= mid.crid %></code></span>
              <span>MID: <code><%= mid.mid %></code></span>
            </div>
          </a>
        <% end
      end
    end %>
  <% else %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :id_badge)
      bs.with_heading(tag: :h3) { "No mailer IDs yet" }
      bs.with_primary_action(href: new_usps_mailer_id_path) { "Add one" }
    end %>
  <% end %>
</div>
