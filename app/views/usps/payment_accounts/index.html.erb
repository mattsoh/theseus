<% content_for :title, "USPS Payment Accounts" %>

<div class="page-container">
  <div class="page-header">
    <div>
      <h1 class="page-title">USPS Payment Accounts</h1>
      <p class="page-subtitle"><%= @usps_payment_accounts.count %> accounts</p>
    </div>
    <%= render Primer::Beta::Button.new(tag: :a, href: new_usps_payment_account_path, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :plus)
      "New Account"
    end %>
  </div>

  <% if @usps_payment_accounts.any? %>
    <%= render Primer::Beta::BorderBox.new do |box|
      @usps_payment_accounts.each do |account|
        box.with_row do %>
          <a href="<%= usps_payment_account_path(account) %>" class="resource-card link-reset">
            <span class="resource-card-title"><%= account.display_name %></span>
            <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :small)) { account.account_type } %>
          </a>
        <% end
      end
    end %>
  <% else %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :credit_card)
      bs.with_heading(tag: :h3) { "No payment accounts yet" }
      bs.with_primary_action(href: new_usps_payment_account_path) { "Add one" }
    end %>
  <% end %>
</div>
