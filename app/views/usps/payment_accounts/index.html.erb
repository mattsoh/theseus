<% content_for :title, "USPS Payment Accounts" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <div>
      <h1 style="font-size: 24px; font-weight: 600; margin: 0;">USPS Payment Accounts</h1>
      <p style="color: var(--fgColor-muted); margin: 4px 0 0; font-size: 14px;"><%= @usps_payment_accounts.count %> accounts</p>
    </div>
    <%= render Primer::Beta::Button.new(tag: :a, href: new_usps_payment_account_path, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :plus)
      "New Account"
    end %>
  </div>

  <% if @usps_payment_accounts.any? %>
    <%= render Primer::Beta::BorderBox.new do |box|
      @usps_payment_accounts.each do |account|
        box.with_row do %>
          <a href="<%= usps_payment_account_path(account) %>" style="display: flex; justify-content: space-between; align-items: center; width: 100%; text-decoration: none; color: inherit;">
            <span style="font-weight: 600;"><%= account.display_name %></span>
            <div style="display: flex; gap: 8px;">
              <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :small)) { account.account_type } %>
            </div>
          </a>
        <% end
      end
    end %>
  <% else %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :credit_card)
      bs.with_heading(tag: :h3) { "No payment accounts yet" }
      bs.with_primary_action(href: new_usps_payment_account_path) { "Add one" }
    end %>
  <% end %>
</div>
