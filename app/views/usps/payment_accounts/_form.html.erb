<%= form_with(model: usps_payment_account) do |form| %>
  <% if usps_payment_account.errors.any? %>
    <%= render Primer::Beta::Flash.new(scheme: :danger, mb: 3) do %>
      <strong><%= pluralize(usps_payment_account.errors.count, "error") %>:</strong>
      <ul style="margin: 8px 0 0 16px; padding: 0;">
        <% usps_payment_account.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box| %>
    <% box.with_header do |header| %>
      <% header.with_title(tag: :h2) do %>Account Details<% end %>
    <% end %>
    <% box.with_body do %>
      <%= render Primer::Alpha::TextField.new(
        name: "usps_payment_account[name]",
        label: "Display name",
        value: usps_payment_account.name,
        full_width: true,
        mb: 3
      ) %>

      <div style="margin-bottom: 12px;">
        <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px;">CRID/MID</label>
        <%= form.collection_select(:usps_mailer_id_id, USPS::MailerId.all, :id, :display_name,
          { prompt: 'Select one...', selected: usps_payment_account.usps_mailer_id_id },
          { required: true, style: "width: 100%; padding: 5px 12px; border: 1px solid var(--borderColor-default); border-radius: 6px; font-size: 14px; background: var(--bgColor-default); color: var(--fgColor-default);" }) %>
      </div>

      <div x-data="{account_type: '<%= usps_payment_account.account_type %>'}" style="margin-bottom: 12px;">
        <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px;">Account type</label>
        <%= form.select :account_type, USPS::PaymentAccount.account_types.keys,
          { selected: usps_payment_account.account_type },
          { 'x-model' => 'account_type', style: "padding: 5px 12px; border: 1px solid var(--borderColor-default); border-radius: 6px; font-size: 14px; background: var(--bgColor-default); color: var(--fgColor-default);" } %>

        <template x-if="account_type=='EPS'">
          <div style="margin-top: 12px;">
            <%= render Primer::Alpha::TextField.new(
              name: "usps_payment_account[account_number]",
              label: "EPS account number",
              value: usps_payment_account.account_number,
              full_width: true
            ) %>
          </div>
        </template>
        <template x-if="account_type=='PERMIT'">
          <div style="margin-top: 12px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
            <div>
              <%= render Primer::Alpha::TextField.new(
                name: "usps_payment_account[permit_number]",
                label: "Permit number",
                value: usps_payment_account.permit_number,
                full_width: true
              ) %>
            </div>
            <div>
              <%= render Primer::Alpha::TextField.new(
                name: "usps_payment_account[permit_zip]",
                label: "Permit ZIP",
                value: usps_payment_account.permit_zip,
                full_width: true
              ) %>
            </div>
          </div>
        </template>
      </div>

      <%= render Primer::Alpha::TextField.new(
        name: "usps_payment_account[manifest_mid]",
        label: "Manifest MID",
        value: usps_payment_account.manifest_mid,
        full_width: true
      ) %>
    <% end %>
  <% end %>

  <div style="display: flex; gap: 8px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: usps_payment_accounts_path, scheme: :secondary) do
      "Cancel"
    end %>
    <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :check)
      usps_payment_account.persisted? ? "Update Account" : "Create Account"
    end %>
  </div>
<% end %>
