<% content_for :title, @usps_payment_account.display_name %>

<div style="max-width: 800px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;">
    <div>
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
        <h1 style="font-size: 24px; font-weight: 600; margin: 0;"><%= @usps_payment_account.display_name %></h1>
        <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :large)) { @usps_payment_account.account_type } %>
      </div>
    </div>
    <div style="display: flex; gap: 8px;">
      <%= render Primer::Beta::Button.new(tag: :a, href: edit_usps_payment_account_path(@usps_payment_account), scheme: :secondary, size: :medium) do |btn|
        btn.with_leading_visual_icon(icon: :pencil)
        "Edit"
      end %>
      <%= form_with url: usps_payment_account_path(@usps_payment_account), method: :delete, data: { turbo_confirm: "Delete this payment account?" }, style: "display: inline;" do %>
        <%= render Primer::Beta::Button.new(type: :submit, scheme: :danger, size: :medium) do |btn|
          btn.with_leading_visual_icon(icon: :trash)
          "Delete"
        end %>
      <% end %>
    </div>
  </div>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box|
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Name</span><span><%= @usps_payment_account.name %></span></div>
    <% end
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Account Type</span><span><%= @usps_payment_account.account_type %></span></div>
    <% end
    if @usps_payment_account.account_number.present?
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Account Number</span><code><%= @usps_payment_account.account_number %></code></div>
      <% end
    end
    if @usps_payment_account.permit_number.present?
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Permit Number</span><code><%= @usps_payment_account.permit_number %></code></div>
      <% end
    end
    if @usps_payment_account.permit_zip.present?
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Permit ZIP</span><code><%= @usps_payment_account.permit_zip %></code></div>
      <% end
    end
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Manifest MID</span><code><%= @usps_payment_account.manifest_mid || "—" %></code></div>
    <% end
    box.with_row do %>
      <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Mailer ID</span><span><%= @usps_payment_account.usps_mailer_id&.display_name || "—" %></span></div>
    <% end
  end %>

  <%= render partial: "admin_inspector", locals: { record: @usps_payment_account } %>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to payment accounts", usps_payment_accounts_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
