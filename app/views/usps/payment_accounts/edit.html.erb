<% content_for :title, "Edit Payment Account" %>

<div class="page-container--xs">
  <div class="page-title-group" style="margin-bottom: 24px;">
    <h1 class="page-title">Edit Payment Account</h1>
    <span class="kv-label"><%= @usps_payment_account.display_name %></span>
  </div>
  <%= render "form", usps_payment_account: @usps_payment_account %>
  <div style="margin-top: 32px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: usps_payment_account_path(@usps_payment_account), scheme: :invisible, size: :small) do |btn|
      btn.with_leading_visual_icon(icon: :"arrow-left")
      "Back to account"
    end %>
  </div>
</div>
