<div id="<%= dom_id payment_account %>" style="padding: 12px 16px; border: 1px solid var(--borderColor-default); border-radius: 6px; margin-bottom: 8px;">
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <a href="<%= usps_payment_account_path(payment_account) %>" style="font-weight: 600; color: var(--fgColor-accent); text-decoration: none;"><%= payment_account.display_name %></a>
    <%= render(Primer::Beta::Label.new(scheme: :secondary, size: :small)) { payment_account.account_type } %>
  </div>
</div>
