<%= form_with(model: usps_indicium) do |form| %>
  <% if usps_indicium.errors.any? %>
    <%= render Primer::Beta::Flash.new(scheme: :danger, mb: 3) do %>
      <strong><%= pluralize(usps_indicium.errors.count, "error") %>:</strong>
      <ul style="margin: 8px 0 0 16px; padding: 0;">
        <% usps_indicium.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    <% end %>
  <% end %>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box| %>
    <% box.with_header do |header| %>
      <% header.with_title(tag: :h2) do %>Postage<% end %>
    <% end %>
    <% box.with_body do %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "usps_indicium[postage]",
            label: "Postage",
            value: usps_indicium.postage,
            full_width: true,
            leading_visual: { text: "$" }
          ) %>
        </div>
        <div>
          <label style="display: block; font-size: 14px; font-weight: 600; margin-bottom: 4px;">Mailing Date</label>
          <%= form.date_field :mailing_date, style: "padding: 5px 12px; border: 1px solid var(--borderColor-default); border-radius: 6px; font-size: 14px; background: var(--bgColor-default); color: var(--fgColor-default);" %>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "usps_indicium[usps_sku]",
            label: "USPS SKU",
            value: usps_indicium.usps_sku,
            full_width: true
          ) %>
        </div>
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "usps_indicium[processing_category]",
            label: "Processing category",
            value: usps_indicium.processing_category,
            full_width: true
          ) %>
        </div>
      </div>
    <% end %>
  <% end %>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box| %>
    <% box.with_header do |header| %>
      <% header.with_title(tag: :h2) do %>Dimensions<% end %>
    <% end %>
    <% box.with_body do %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "usps_indicium[postage_weight]",
            label: "Weight (oz)",
            value: usps_indicium.postage_weight,
            full_width: true
          ) %>
        </div>
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "usps_indicium[postage_length]",
            label: "Length (in)",
            value: usps_indicium.postage_length,
            full_width: true
          ) %>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "usps_indicium[postage_height]",
            label: "Height (in)",
            value: usps_indicium.postage_height,
            full_width: true
          ) %>
        </div>
        <div>
          <%= render Primer::Alpha::TextField.new(
            name: "usps_indicium[postage_thickness]",
            label: "Thickness (in)",
            value: usps_indicium.postage_thickness,
            full_width: true
          ) %>
        </div>
      </div>
      <%= render Primer::Alpha::CheckBox.new(
        name: "usps_indicium[nonmachinable]",
        label: "Non-machinable",
        checked: usps_indicium.nonmachinable
      ) %>
    <% end %>
  <% end %>

  <%= render Primer::Beta::BorderBox.new(mb: 4) do |box| %>
    <% box.with_header do |header| %>
      <% header.with_title(tag: :h2) do %>Raw Response<% end %>
    <% end %>
    <% box.with_body do %>
      <%= render Primer::Alpha::TextArea.new(
        name: "usps_indicium[raw_usps_response]",
        label: "Raw USPS response",
        value: usps_indicium.raw_usps_response,
        rows: 4,
        full_width: true
      ) %>
    <% end %>
  <% end %>

  <div style="display: flex; gap: 8px;">
    <%= render Primer::Beta::Button.new(tag: :a, href: usps_indicia_path, scheme: :secondary) do
      "Cancel"
    end %>
    <%= render Primer::Beta::Button.new(type: :submit, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :check)
      usps_indicium.persisted? ? "Update Indicium" : "Create Indicium"
    end %>
  </div>
<% end %>
