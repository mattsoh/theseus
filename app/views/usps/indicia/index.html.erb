<% content_for :title, "Indicia" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <div>
      <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Indicia</h1>
      <p style="color: var(--fgColor-muted); margin: 4px 0 0; font-size: 14px;"><%= @usps_indicia.count %> purchased</p>
    </div>
    <%= render Primer::Beta::Button.new(tag: :a, href: new_usps_indicium_path, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :plus)
      "New Indicium"
    end %>
  </div>

  <% if @usps_indicia.any? %>
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_header do %>
        <div class="indicia-row">
          <span class="indicia-col-id" style="font-weight: 600;">ID</span>
          <code class="indicia-col-sku" style="font-weight: 600;">SKU</code>
          <span class="indicia-col-num" style="font-weight: 600;">Postage</span>
          <span class="indicia-col-date" style="font-weight: 600;">Date</span>
          <span class="indicia-col-cat" style="font-weight: 600;">Category</span>
        </div>
      <% end

      @usps_indicia.each do |indicium|
        box.with_row do %>
          <a href="<%= usps_indicium_path(indicium) %>" class="indicia-row" style="text-decoration: none; color: inherit;">
            <span class="indicia-col-id"><%= render Components::Shared::PublicId.new(value: indicium.public_id) %></span>
            <code class="indicia-col-sku" style="font-size: 12px;"><%= indicium.usps_sku %></code>
            <span class="indicia-col-num" style="font-weight: 500;"><%= number_to_currency(indicium.postage) %></span>
            <span class="indicia-col-date" style="color: var(--fgColor-muted);"><%= indicium.mailing_date %></span>
            <span class="indicia-col-cat" style="color: var(--fgColor-muted);"><%= indicium.processing_category %></span>
          </a>
        <% end
      end
    end %>
  <% else %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :mail)
      bs.with_heading(tag: :h3) { "No indicia yet" }
      bs.with_description { "Purchased postage will appear here." }
    end %>
  <% end %>
</div>

<style>
  .indicia-row { display: flex; align-items: center; gap: 16px; width: 100%; }
  .indicia-col-id { flex: 1; }
  .indicia-col-sku { min-width: 100px; flex-shrink: 0; }
  .indicia-col-num { min-width: 80px; text-align: right; flex-shrink: 0; }
  .indicia-col-date { min-width: 100px; flex-shrink: 0; }
  .indicia-col-cat { min-width: 80px; flex-shrink: 0; }
</style>
