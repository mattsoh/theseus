<% content_for :title, "Indicia" %>

<div style="max-width: 1200px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <div>
      <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Indicia</h1>
      <p style="color: var(--fgColor-muted); margin: 4px 0 0; font-size: 14px;"><%= @usps_indicia.count %> purchased</p>
    </div>
    <%= render Primer::Beta::Button.new(tag: :a, href: new_usps_indicium_path, scheme: :primary) do |btn|
      btn.with_leading_visual_icon(icon: :plus)
      "New Indicium"
    end %>
  </div>

  <% if @usps_indicia.any? %>
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_header do %>
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
          <span style="font-weight: 600;">ID</span>
          <div style="display: flex; gap: 48px;">
            <span style="font-weight: 600; min-width: 100px;">SKU</span>
            <span style="font-weight: 600; min-width: 80px; text-align: right;">Postage</span>
            <span style="font-weight: 600; min-width: 100px;">Date</span>
            <span style="font-weight: 600; min-width: 80px;">Category</span>
          </div>
        </div>
      <% end

      @usps_indicia.each do |indicium|
        box.with_row do %>
          <a href="<%= usps_indicium_path(indicium) %>" style="display: flex; justify-content: space-between; align-items: center; width: 100%; text-decoration: none; color: inherit;">
            <div><%= render Components::Shared::PublicId.new(value: indicium.public_id) %></div>
            <div style="display: flex; gap: 48px; align-items: center;">
              <code style="min-width: 100px; font-size: 12px;"><%= indicium.usps_sku %></code>
              <span style="min-width: 80px; text-align: right; font-weight: 500;"><%= number_to_currency(indicium.postage) %></span>
              <span style="min-width: 100px; color: var(--fgColor-muted);"><%= indicium.mailing_date %></span>
              <span style="min-width: 80px; color: var(--fgColor-muted);"><%= indicium.processing_category %></span>
            </div>
          </a>
        <% end
      end
    end %>
  <% else %>
    <%= render Primer::Beta::Blankslate.new(border: true) do |bs|
      bs.with_visual_icon(icon: :mail)
      bs.with_heading(tag: :h3) { "No indicia yet" }
      bs.with_description { "Purchased postage will appear here." }
    end %>
  <% end %>
</div>
