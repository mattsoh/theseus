<% content_for :title, "Indicium #{@usps_indicium.public_id}" %>

<div style="max-width: 800px; margin: 0 auto; padding: 24px;">
  <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px;">
    <div>
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 4px;">
        <h1 style="font-size: 24px; font-weight: 600; margin: 0;">Indicium</h1>
      </div>
      <p style="color: var(--fgColor-muted); margin: 0; font-size: 14px;">
        <%= render Components::Shared::PublicId.new(value: @usps_indicium.public_id) %>
      </p>
    </div>
    <div style="display: flex; gap: 8px;">
      <%= render Primer::Beta::Button.new(tag: :a, href: edit_usps_indicium_path(@usps_indicium), scheme: :secondary, size: :medium) do |btn|
        btn.with_leading_visual_icon(icon: :pencil)
        "Edit"
      end %>
      <%= form_with url: usps_indicium_path(@usps_indicium), method: :delete, data: { turbo_confirm: "Delete this indicium?" }, style: "display: inline;" do %>
        <%= render Primer::Beta::Button.new(type: :submit, scheme: :danger, size: :medium) do |btn|
          btn.with_leading_visual_icon(icon: :trash)
          "Delete"
        end %>
      <% end %>
    </div>
  </div>

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Postage Details</h2>
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Postage</span><span style="font-weight: 600; font-size: 16px;"><%= number_to_currency(@usps_indicium.postage) %></span></div>
      <% end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Mailing Date</span><span><%= @usps_indicium.mailing_date %></span></div>
      <% end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">USPS SKU</span><code><%= @usps_indicium.usps_sku %></code></div>
      <% end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Processing Category</span><span><%= @usps_indicium.processing_category %></span></div>
      <% end
    end %>
  </div>

  <div style="margin-bottom: 24px;">
    <h2 style="font-size: 14px; font-weight: 600; margin: 0 0 12px 0;">Dimensions</h2>
    <%= render Primer::Beta::BorderBox.new do |box|
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Weight</span><span><%= @usps_indicium.postage_weight %> oz</span></div>
      <% end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Length</span><span><%= @usps_indicium.postage_length %>"</span></div>
      <% end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Height</span><span><%= @usps_indicium.postage_height %>"</span></div>
      <% end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Thickness</span><span><%= @usps_indicium.postage_thickness %>"</span></div>
      <% end
      box.with_row do %>
        <div style="display: flex; justify-content: space-between;"><span style="color: var(--fgColor-muted);">Non-machinable</span><span><%= @usps_indicium.nonmachinable ? "Yes" : "No" %></span></div>
      <% end
    end %>
  </div>

  <%= render partial: "admin_inspector", locals: { record: @usps_indicium } %>

  <div style="margin-top: 32px;">
    <%= link_to "← Back to indicia", usps_indicia_path, style: "color: var(--fgColor-muted); text-decoration: none;" %>
  </div>
</div>
