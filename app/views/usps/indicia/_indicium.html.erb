<div id="<%= dom_id indicium %>" style="padding: 12px 16px; border: 1px solid var(--borderColor-default); border-radius: 6px; margin-bottom: 8px;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
    <%= render Components::Shared::PublicId.new(value: indicium.public_id) %>
    <span style="font-weight: 600;"><%= number_to_currency(indicium.postage) %></span>
  </div>
  <div style="display: flex; gap: 24px; font-size: 13px; color: var(--fgColor-muted);">
    <span>SKU: <code style="font-size: 12px;"><%= indicium.usps_sku %></code></span>
    <span><%= indicium.mailing_date %></span>
    <span><%= indicium.processing_category %></span>
  </div>
</div>
